 315:Core/Src/system_stm32h7xx.c **** /**
 316:Core/Src/system_stm32h7xx.c ****   * @brief  Update SystemCoreClock variable according to Clock Register Values.
 317:Core/Src/system_stm32h7xx.c ****   *         The SystemCoreClock variable contains the core clock , it can
 318:Core/Src/system_stm32h7xx.c ****   *         be used by the user application to setup the SysTick timer or configure
 319:Core/Src/system_stm32h7xx.c ****   *         other parameters.
ARM GAS  C:\Users\27655\AppData\Local\Temp\cc6qhVqT.s 			page 10


 320:Core/Src/system_stm32h7xx.c ****   *
 321:Core/Src/system_stm32h7xx.c ****   * @note   Each time the core clock changes, this function must be called
 322:Core/Src/system_stm32h7xx.c ****   *         to update SystemCoreClock variable value. Otherwise, any configuration
 323:Core/Src/system_stm32h7xx.c ****   *         based on this variable will be incorrect.
 324:Core/Src/system_stm32h7xx.c ****   *
 325:Core/Src/system_stm32h7xx.c ****   * @note   - The system frequency computed by this function is not the real
 326:Core/Src/system_stm32h7xx.c ****   *           frequency in the chip. It is calculated based on the predefined
 327:Core/Src/system_stm32h7xx.c ****   *           constant and the selected clock source:
 328:Core/Src/system_stm32h7xx.c ****   *
 329:Core/Src/system_stm32h7xx.c ****   *           - If SYSCLK source is CSI, SystemCoreClock will contain the CSI_VALUE(*)
 330:Core/Src/system_stm32h7xx.c ****   *           - If SYSCLK source is HSI, SystemCoreClock will contain the HSI_VALUE(**)
 331:Core/Src/system_stm32h7xx.c ****   *           - If SYSCLK source is HSE, SystemCoreClock will contain the HSE_VALUE(***)
 332:Core/Src/system_stm32h7xx.c ****   *           - If SYSCLK source is PLL, SystemCoreClock will contain the CSI_VALUE(*),
 333:Core/Src/system_stm32h7xx.c ****   *             HSI_VALUE(**) or HSE_VALUE(***) multiplied/divided by the PLL factors.
 334:Core/Src/system_stm32h7xx.c ****   *
 335:Core/Src/system_stm32h7xx.c ****   *         (*) CSI_VALUE is a constant defined in stm32h7xx_hal.h file (default value
 336:Core/Src/system_stm32h7xx.c ****   *             4 MHz) but the real value may vary depending on the variations
 337:Core/Src/system_stm32h7xx.c ****   *             in voltage and temperature.
 338:Core/Src/system_stm32h7xx.c ****   *         (**) HSI_VALUE is a constant defined in stm32h7xx_hal.h file (default value
 339:Core/Src/system_stm32h7xx.c ****   *             64 MHz) but the real value may vary depending on the variations
 340:Core/Src/system_stm32h7xx.c ****   *             in voltage and temperature.
 341:Core/Src/system_stm32h7xx.c ****   *
 342:Core/Src/system_stm32h7xx.c ****   *         (***)HSE_VALUE is a constant defined in stm32h7xx_hal.h file (default value
 343:Core/Src/system_stm32h7xx.c ****   *              25 MHz), user has to ensure that HSE_VALUE is same as the real
 344:Core/Src/system_stm32h7xx.c ****   *              frequency of the crystal used. Otherwise, this function may
 345:Core/Src/system_stm32h7xx.c ****   *              have wrong result.
 346:Core/Src/system_stm32h7xx.c ****   *
 347:Core/Src/system_stm32h7xx.c ****   *         - The result of this function could be not correct when using fractional
 348:Core/Src/system_stm32h7xx.c ****   *           value for HSE crystal.
 349:Core/Src/system_stm32h7xx.c ****   * @param  None
 350:Core/Src/system_stm32h7xx.c ****   * @retval None
 351:Core/Src/system_stm32h7xx.c ****   */
 352:Core/Src/system_stm32h7xx.c **** void SystemCoreClockUpdate (void)
