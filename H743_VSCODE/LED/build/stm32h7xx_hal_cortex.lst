2201:Drivers/CMSIS/Include/core_cm7.h ****   \brief   get FPU type
2202:Drivers/CMSIS/Include/core_cm7.h ****   \details returns the FPU type
2203:Drivers/CMSIS/Include/core_cm7.h ****   \returns
2204:Drivers/CMSIS/Include/core_cm7.h ****    - \b  0: No FPU
2205:Drivers/CMSIS/Include/core_cm7.h ****    - \b  1: Single precision FPU
2206:Drivers/CMSIS/Include/core_cm7.h ****    - \b  2: Double + Single precision FPU
2207:Drivers/CMSIS/Include/core_cm7.h ****  */
2208:Drivers/CMSIS/Include/core_cm7.h **** __STATIC_INLINE uint32_t SCB_GetFPUType(void)
2209:Drivers/CMSIS/Include/core_cm7.h **** {
2210:Drivers/CMSIS/Include/core_cm7.h ****   uint32_t mvfr0;
2211:Drivers/CMSIS/Include/core_cm7.h **** 
2212:Drivers/CMSIS/Include/core_cm7.h ****   mvfr0 = SCB->MVFR0;
2213:Drivers/CMSIS/Include/core_cm7.h ****   if      ((mvfr0 & (FPU_MVFR0_Single_precision_Msk | FPU_MVFR0_Double_precision_Msk)) == 0x220U)
2214:Drivers/CMSIS/Include/core_cm7.h ****   {
2215:Drivers/CMSIS/Include/core_cm7.h ****     return 2U;           /* Double + Single precision FPU */
2216:Drivers/CMSIS/Include/core_cm7.h ****   }
2217:Drivers/CMSIS/Include/core_cm7.h ****   else if ((mvfr0 & (FPU_MVFR0_Single_precision_Msk | FPU_MVFR0_Double_precision_Msk)) == 0x020U)
2218:Drivers/CMSIS/Include/core_cm7.h ****   {
2219:Drivers/CMSIS/Include/core_cm7.h ****     return 1U;           /* Single precision FPU */
2220:Drivers/CMSIS/Include/core_cm7.h ****   }
2221:Drivers/CMSIS/Include/core_cm7.h ****   else
2222:Drivers/CMSIS/Include/core_cm7.h ****   {
2223:Drivers/CMSIS/Include/core_cm7.h ****     return 0U;           /* No FPU */
2224:Drivers/CMSIS/Include/core_cm7.h ****   }
2225:Drivers/CMSIS/Include/core_cm7.h **** }
