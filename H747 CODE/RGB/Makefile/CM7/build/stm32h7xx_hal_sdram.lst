   5:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_sdram.c ****   * @brief   SDRAM HAL module driver.
   6:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_sdram.c ****   *          This file provides a generic firmware to drive SDRAM memories mounted
   7:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_sdram.c ****   *          as external device.
   8:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_sdram.c ****   *
   9:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_sdram.c ****   ******************************************************************************
