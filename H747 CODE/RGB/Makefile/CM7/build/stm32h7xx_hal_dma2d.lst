 931:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_dma2d.c ****   /* Check whether or not a transfer is actually suspended and change the DMA2D state accordingly *
 932:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_dma2d.c ****   if ((hdma2d->Instance->CR & DMA2D_CR_START) != 0U)
 933:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_dma2d.c ****   {
 934:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_dma2d.c ****     hdma2d->State = HAL_DMA2D_STATE_SUSPEND;
