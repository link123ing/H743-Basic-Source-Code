 703:../../Middlewares/LVGL/GUI/lvgl/src/widgets/image/lv_image.c ****         int32_t * s = lv_event_get_param(e);
 704:../../Middlewares/LVGL/GUI/lvgl/src/widgets/image/lv_image.c **** 
 705:../../Middlewares/LVGL/GUI/lvgl/src/widgets/image/lv_image.c ****         /*If the image has angle provide enough room for the rotated corners*/
