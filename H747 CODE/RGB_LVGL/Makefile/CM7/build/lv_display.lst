 174:../../Middlewares/LVGL/GUI/lvgl/src/display/lv_display.c **** {
 175:../../Middlewares/LVGL/GUI/lvgl/src/display/lv_display.c ****     bool was_default = false;
 176:../../Middlewares/LVGL/GUI/lvgl/src/display/lv_display.c ****     bool was_refr = false;
