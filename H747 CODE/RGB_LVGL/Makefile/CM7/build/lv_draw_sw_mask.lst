 318:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     /*Try to reuse a circle cache entry*/
 319:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     for(i = 0; i < LV_DRAW_SW_CIRCLE_CACHE_SIZE; i++) {
 320:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         if(_circle_cache[i].radius == radius) {
 321:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             _circle_cache[i].used_cnt++;
 322:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             CIRCLE_CACHE_AGING(_circle_cache[i].life, radius);
 323:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             param->circle = &(_circle_cache[i]);
 324:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             lv_mutex_unlock(&circle_cache_mutex);
 325:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             return;
