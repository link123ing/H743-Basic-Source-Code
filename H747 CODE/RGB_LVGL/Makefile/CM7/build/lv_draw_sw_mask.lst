 223:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c **** void lv_draw_sw_mask_line_angle_init(lv_draw_sw_mask_line_param_t * param, int32_t p1x, int32_t py,
 224:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****                                      lv_draw_sw_mask_line_side_t side)
 225:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c **** {
 226:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     /*Find an optimal degree.
 227:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****      *lv_mask_line_points_init will swap the points to keep the smaller y in p1
 228:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****      *Theoretically a line with `angle` or `angle+180` is the same only the points are swapped
 229:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****      *Find the degree which keeps the origo in place*/
 230:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     if(angle > 180) angle -= 180; /*> 180 will swap the origo*/
 231:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 232:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t p2x;
