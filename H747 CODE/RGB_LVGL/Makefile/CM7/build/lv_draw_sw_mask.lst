1188:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = tmp_val >> (10 + 6);
1189:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = 15 - tmp_val;
1190:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
1191:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
1192:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         cir_x[cir_size] = mid_int;
