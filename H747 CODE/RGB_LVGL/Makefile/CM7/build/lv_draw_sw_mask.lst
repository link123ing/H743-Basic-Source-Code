1176:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     /*The point on the 1/8 circle is special, calculate it manually*/
1177:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t mid = radius * 723;
1178:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t mid_int = mid >> 10;
1179:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     if(cir_x[cir_size - 1] != mid_int || cir_y[cir_size - 1] != mid_int) {
1180:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         int32_t tmp_val = mid - (mid_int << 10);
1181:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         if(tmp_val <= 512) {
1182:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = tmp_val * tmp_val * 2;
1183:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             tmp_val = tmp_val >> (10 + 6);
1184:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
1185:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         else {
