 297:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t w = lv_area_get_width(rect);
 298:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t h = lv_area_get_height(rect);
 299:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     int32_t short_side = LV_MIN(w, h);
 300:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     if(radius > short_side >> 1) radius = short_side >> 1;
 301:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     if(radius < 0) radius = 0;
 302:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 303:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     lv_area_copy(&param->cfg.rect, rect);
 304:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     param->cfg.radius = radius;
