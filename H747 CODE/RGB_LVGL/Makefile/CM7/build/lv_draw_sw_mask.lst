 333:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             if(!entry) entry = &(_circle_cache[i]);
 334:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****             else if(_circle_cache[i].life < entry->life) entry = &(_circle_cache[i]);
 335:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****         }
