 329:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     /*If not cached use the free entry with lowest life*/
 330:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     lv_draw_sw_mask_radius_circle_dsc_t * entry = NULL;
