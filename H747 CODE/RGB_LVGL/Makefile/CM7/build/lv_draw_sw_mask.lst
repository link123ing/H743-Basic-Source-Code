 235:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     p2x = (lv_trigo_sin(angle + 90) >> 5) + p1x;
 236:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     p2y = (lv_trigo_sin(angle) >> 5) + py;
 237:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c **** 
 238:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c ****     lv_draw_sw_mask_line_points_init(param, p1x, py, p2x, p2y, side);
 239:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_mask.c **** }
