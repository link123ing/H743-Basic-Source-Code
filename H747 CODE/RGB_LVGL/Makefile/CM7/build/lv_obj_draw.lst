 346:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     int32_t h = lv_obj_get_style_transform_height(obj, part);
 347:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     int32_t wh = LV_MAX(w, h);
 348:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     if(wh > 0) s += wh;
