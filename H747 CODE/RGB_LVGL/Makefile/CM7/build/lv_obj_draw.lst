 337:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     if(outline_width) {
 338:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****         lv_opa_t outline_opa = lv_obj_get_style_outline_opa(obj, part);
 339:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****         if(outline_opa > LV_OPA_MIN) {
