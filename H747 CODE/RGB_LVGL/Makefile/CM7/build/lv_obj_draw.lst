 318:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c **** int32_t lv_obj_calculate_ext_draw_size(lv_obj_t * obj, lv_part_t part)
 319:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c **** {
 320:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 321:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     int32_t s = 0;
 322:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c **** 
 323:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     int32_t sh_width = lv_obj_get_style_shadow_width(obj, part);
 324:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     if(sh_width) {
 325:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****         lv_opa_t sh_opa = lv_obj_get_style_shadow_opa(obj, part);
 326:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****         if(sh_opa > LV_OPA_MIN) {
 327:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****             sh_width = sh_width / 2 + 1;    /*The blur adds only half width*/
 328:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****             sh_width += lv_obj_get_style_shadow_spread(obj, part);
 329:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****             int32_t sh_ofs_x = lv_obj_get_style_shadow_offset_x(obj, part);
 330:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****             int32_t sh_ofs_y = lv_obj_get_style_shadow_offset_y(obj, part);
 331:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****             sh_width += LV_MAX(LV_ABS(sh_ofs_x), LV_ABS(sh_ofs_y));
 332:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****             s = LV_MAX(s, sh_width);
 333:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****         }
 334:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c ****     }
 335:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_draw.c **** 
