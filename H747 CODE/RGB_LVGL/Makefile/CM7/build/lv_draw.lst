 599:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  * Clean-up resources allocated by a finished task
 600:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  * @param t         pointer to a draw task
 601:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  * @param disp      pointer to a display on which the task was drawn
 602:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  */
 603:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** static void cleanup_task(lv_draw_task_t * t, lv_display_t * disp)
 604:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** {
 605:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 606:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     /*If it was layer drawing free the layer too*/
 607:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     if(t->type == LV_DRAW_TASK_TYPE_LAYER) {
 608:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         lv_draw_image_dsc_t * draw_image_dsc = t->draw_dsc;
