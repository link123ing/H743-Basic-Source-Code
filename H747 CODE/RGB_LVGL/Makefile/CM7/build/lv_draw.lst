 519:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** /**
 520:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  * Check if there are older draw task overlapping the area of `t_check`
 521:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  * @param layer      the draw ctx to search in
 522:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  * @param t_check       check this task if it overlaps with the older ones
 523:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  * @return              true: `t_check` is not overlapping with older tasks so it's independent
 524:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****  */
 525:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** static bool is_independent(lv_layer_t * layer, lv_draw_task_t * t_check)
 526:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** {
 527:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 528:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     lv_draw_task_t * t = layer->draw_task_head;
 529:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 530:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     /*If t_check is outside of the older tasks then it's independent*/
 531:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     while(t && t != t_check) {
 532:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         if(t->state != LV_DRAW_TASK_STATE_READY) {
 533:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             lv_area_t a;
 534:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             if(lv_area_intersect(&a, &t->_real_area, &t_check->_real_area)) {
 535:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 LV_PROFILER_DRAW_END;
 536:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 return false;
 537:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             }
 538:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 539:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         t = t->next;
 540:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     }
 541:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_END;
 542:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 543:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     return true;
 544:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** }
