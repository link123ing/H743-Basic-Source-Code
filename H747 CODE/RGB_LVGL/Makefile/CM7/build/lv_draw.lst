 610:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 611:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         if(layer_drawn->draw_buf) {
 612:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             int32_t h = lv_area_get_height(&layer_drawn->buf_area);
 613:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             uint32_t layer_size_byte = h * layer_drawn->draw_buf->header.stride;
 614:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 615:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             if(_draw_info.used_memory_for_layers >= layer_size_byte) {
 616:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 _draw_info.used_memory_for_layers -= layer_size_byte;
 617:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             }
 618:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             else {
 619:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 _draw_info.used_memory_for_layers = 0;
 620:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 LV_LOG_WARN("More layers were freed than allocated");
 621:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             }
 622:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             LV_LOG_INFO("Layer memory used: %" LV_PRIu32 " kB", get_layer_size_kb(_draw_info.used_m
 623:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             lv_draw_buf_destroy(layer_drawn->draw_buf);
 624:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             layer_drawn->draw_buf = NULL;
 625:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 626:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 627:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         /*Remove the layer from  the display's*/
 628:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         if(disp) {
 629:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             lv_layer_t * l2 = disp->layer_head;
 630:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             while(l2) {
 631:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 if(l2->next == layer_drawn) {
 632:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                     l2->next = layer_drawn->next;
 633:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                     break;
 634:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 }
 635:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 l2 = l2->next;
 636:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             }
 637:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 638:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             if(disp->layer_deinit) {
 639:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 LV_PROFILER_DRAW_BEGIN_TAG("layer_deinit");
 640:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 disp->layer_deinit(disp, layer_drawn);
 641:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 LV_PROFILER_DRAW_END_TAG("layer_deinit");
 642:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             }
 643:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             lv_free(layer_drawn);
 644:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 645:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     }
