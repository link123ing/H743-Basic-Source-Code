 233:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** bool lv_draw_dispatch_layer(lv_display_t * disp, lv_layer_t * layer)
 234:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** {
 235:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 236:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     /*Remove the finished tasks first*/
 237:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     lv_draw_task_t * t_prev = NULL;
 238:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     lv_draw_task_t * t = layer->draw_task_head;
 239:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     lv_draw_task_t * t_next;
 240:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     bool remove_task = false;
 241:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     while(t) {
 242:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         t_next = t->next;
 243:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         if(t->state == LV_DRAW_TASK_STATE_READY) {
 244:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             cleanup_task(t, disp);
 245:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             remove_task = true;
 246:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             if(t_prev != NULL)
 247:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 t_prev->next = t_next;
 248:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             else
 249:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 layer->draw_task_head = t_next;
 250:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 251:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         else {
 252:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             t_prev = t;
 253:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 254:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         t = t_next;
 255:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     }
 256:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 257:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     bool task_dispatched = false;
 258:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 259:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     /*This layer is ready, enable blending its buffer*/
ARM GAS  C:\Users\28576\AppData\Local\Temp\cc59YylE.s 			page 6


 260:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     if(layer->parent && layer->all_tasks_added && layer->draw_task_head == NULL) {
 261:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         /*Find a draw task with TYPE_LAYER in the layer where the src is this layer*/
 262:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         lv_draw_task_t * t_src = layer->parent->draw_task_head;
 263:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         while(t_src) {
 264:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             if(t_src->type == LV_DRAW_TASK_TYPE_LAYER && t_src->state == LV_DRAW_TASK_STATE_WAITING
 265:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 lv_draw_image_dsc_t * draw_dsc = t_src->draw_dsc;
 266:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 if(draw_dsc->src == layer) {
 267:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                     t_src->state = LV_DRAW_TASK_STATE_QUEUED;
 268:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                     lv_draw_dispatch_request();
 269:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                     break;
 270:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 }
 271:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             }
 272:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             t_src = t_src->next;
 273:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 274:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     }
 275:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     /*Assign draw tasks to the draw_units*/
 276:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     else if(remove_task || layer->draw_task_head) {
 277:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         /*Find a draw unit which is not busy and can take at least one task*/
 278:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         /*Let all draw units to pick draw tasks*/
 279:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         lv_draw_unit_t * u = _draw_info.unit_head;
 280:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         while(u) {
 281:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             LV_PROFILER_DRAW_BEGIN_TAG("dispatch_cb");
 282:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             LV_PROFILER_DRAW_BEGIN_TAG(u->name);
 283:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             int32_t taken_cnt = u->dispatch_cb(u, layer);
 284:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             LV_PROFILER_DRAW_END_TAG(u->name);
 285:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             LV_PROFILER_DRAW_END_TAG("dispatch_cb");
 286:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             if(taken_cnt != LV_DRAW_UNIT_IDLE) task_dispatched = true;
 287:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             u = u->next;
 288:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 289:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     }
 290:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** 
 291:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_END;
 292:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     return task_dispatched;
 293:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** }
