 212:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** void lv_draw_dispatch(void)
 213:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** {
 214:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_BEGIN;
 215:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     bool task_dispatched = false;
 216:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     lv_display_t * disp = lv_display_get_next(NULL);
 217:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     while(disp) {
 218:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         lv_layer_t * layer = disp->layer_head;
 219:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         while(layer) {
 220:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             if(lv_draw_dispatch_layer(disp, layer))
 221:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****                 task_dispatched = true;
 222:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             layer = layer->next;
 223:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 224:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         if(!task_dispatched) {
 225:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             lv_draw_wait_for_finish();
 226:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****             lv_draw_dispatch_request();
 227:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         }
 228:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****         disp = lv_display_get_next(disp);
 229:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     }
 230:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c ****     LV_PROFILER_DRAW_END;
 231:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw.c **** }
