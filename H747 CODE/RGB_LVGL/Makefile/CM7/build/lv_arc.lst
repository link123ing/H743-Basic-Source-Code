 943:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c **** /**
 944:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * Check if angle is within arc background bounds
 945:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  *
 946:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * In order to avoid unexpected value update of the arc value when the user clicks
 947:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * outside of the arc background we need to check if the angle (of the clicked point)
 948:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * is within the bounds of the background.
 949:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  *
 950:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * A tolerance (extra room) also should be taken into consideration.
 951:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  *
 952:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * E.g. Arc with start angle of 0° and end angle of 90°, the background is only visible in
 953:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * that range, from 90° to 360° the background is invisible. Click in 150° should not update
 954:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * the arc value, click within the arc angle range should.
 955:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  *
 956:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * IMPORTANT NOTE: angle is always relative to bg_angle_start, e.g. if bg_angle_start is 30
 957:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * and we click a bit to the left, angle is 10, not the expected 40.
 958:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  *
 959:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * @param obj   Pointer to lv_arc
 960:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * @param angle Angle to be checked. Is 0<=angle<=360 and relative to bg_angle_start
 961:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * @param tolerance_deg Tolerance
 962:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  *
 963:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  * @return true if angle is within arc background bounds, false otherwise
 964:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****  */
 965:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c **** static bool lv_arc_angle_within_bg_bounds(lv_obj_t * obj, const lv_value_precise_t angle,
 966:../../Middlewares/LVGL/GUI/lvgl/src/widgets/arc/lv_arc.c ****                                           const lv_value_precise_t tolerance_deg)
