 157:../../Middlewares/LVGL/GUI/lvgl/src/widgets/switch/lv_switch.c ****         /*The smaller size is the knob diameter*/
 158:../../Middlewares/LVGL/GUI/lvgl/src/widgets/switch/lv_switch.c ****         int32_t knob_size = LV_MAX4(knob_left, knob_right, knob_bottom, knob_top);
