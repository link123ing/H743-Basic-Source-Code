  50:../../BSP/LCD/lcd.c ****  * @brief       ťĘúŤČ≤ŤĹ¨śćĘ
  51:../../BSP/LCD/lcd.c ****  * @note        ŚįÜRGB565ťĘúŤČ≤ŤĹ¨śćĘśąźRGB888ťĘúŤČ≤
  52:../../BSP/LCD/lcd.c ****  * @param       rgb565 : RGB565ťĘúŤČ≤
  53:../../BSP/LCD/lcd.c ****  * @retval      RGB888ťĘúŤČ≤ŚÄľ
  54:../../BSP/LCD/lcd.c ****  */
  55:../../BSP/LCD/lcd.c **** uint32_t lcd_rgb565torgb888(uint16_t rgb565)
  56:../../BSP/LCD/lcd.c **** {
  57:../../BSP/LCD/lcd.c ****     uint16_t r, g, b;
  58:../../BSP/LCD/lcd.c ****     uint32_t rgb888;
  59:../../BSP/LCD/lcd.c ****   
  60:../../BSP/LCD/lcd.c ****     r = (rgb565 & 0XF800) >> 8;
  61:../../BSP/LCD/lcd.c ****     g = (rgb565 & 0X07E0) >> 3;
  62:../../BSP/LCD/lcd.c ****     b = (rgb565 & 0X001F) << 3;
  63:../../BSP/LCD/lcd.c ****   
  64:../../BSP/LCD/lcd.c ****     rgb888 = (r << 16) | (g << 8) | b;
  65:../../BSP/LCD/lcd.c ****   
  66:../../BSP/LCD/lcd.c ****     return rgb888;
  67:../../BSP/LCD/lcd.c **** }
