 351:../../BSP/LCD/lcd.c **** /**
 352:../../BSP/LCD/lcd.c ****  * @brief       ÁĒĽŚúÜ
 353:../../BSP/LCD/lcd.c ****  * @param       x0,y0: ŚúÜšł≠ŚŅÉŚĚźś†á
 354:../../BSP/LCD/lcd.c ****  * @param       r    : ŚćäŚĺĄ
 355:../../BSP/LCD/lcd.c ****  * @param       color: ŚúÜÁöĄťĘúŤČ≤
 356:../../BSP/LCD/lcd.c ****  * @retval      śó†
 357:../../BSP/LCD/lcd.c ****  */
 358:../../BSP/LCD/lcd.c **** void lcd_draw_circle(uint16_t x0, uint16_t y0, uint8_t r, uint32_t color)
 359:../../BSP/LCD/lcd.c **** {
 360:../../BSP/LCD/lcd.c ****     int a, b;
 361:../../BSP/LCD/lcd.c ****     int di;
 362:../../BSP/LCD/lcd.c ****     a = 0;
 363:../../BSP/LCD/lcd.c ****     b = r;
 364:../../BSP/LCD/lcd.c ****     di = 3 - (r << 1);       /* Śą§śĖ≠šłčšł™ÁāĻšĹćÁĹģÁöĄś†áŚŅó */
 365:../../BSP/LCD/lcd.c **** 
 366:../../BSP/LCD/lcd.c ****     while (a <= b)
 367:../../BSP/LCD/lcd.c ****     {
 368:../../BSP/LCD/lcd.c ****         lcd_draw_point(x0 + a, y0 - b, color);  /* 5 */
 369:../../BSP/LCD/lcd.c ****         lcd_draw_point(x0 + b, y0 - a, color);  /* 0 */
 370:../../BSP/LCD/lcd.c ****         lcd_draw_point(x0 + b, y0 + a, color);  /* 4 */
 371:../../BSP/LCD/lcd.c ****         lcd_draw_point(x0 + a, y0 + b, color);  /* 6 */
 372:../../BSP/LCD/lcd.c ****         lcd_draw_point(x0 - a, y0 + b, color);  /* 1 */
 373:../../BSP/LCD/lcd.c ****         lcd_draw_point(x0 - b, y0 + a, color);
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccA8hrCI.s 			page 8


 374:../../BSP/LCD/lcd.c ****         lcd_draw_point(x0 - a, y0 - b, color);  /* 2 */
 375:../../BSP/LCD/lcd.c ****         lcd_draw_point(x0 - b, y0 - a, color);  /* 7 */
 376:../../BSP/LCD/lcd.c ****         a++;
 377:../../BSP/LCD/lcd.c **** 
 378:../../BSP/LCD/lcd.c ****         /* šĹŅÁĒ®BresenhamÁģóś≥ēÁĒĽŚúÜ */
 379:../../BSP/LCD/lcd.c ****         if (di < 0)
 380:../../BSP/LCD/lcd.c ****         {
 381:../../BSP/LCD/lcd.c ****             di += 4 * a + 6;
 382:../../BSP/LCD/lcd.c ****         }
 383:../../BSP/LCD/lcd.c ****         else
 384:../../BSP/LCD/lcd.c ****         {
 385:../../BSP/LCD/lcd.c ****             di += 10 + 4 * (a - b);
 386:../../BSP/LCD/lcd.c ****             b--;
 387:../../BSP/LCD/lcd.c ****         }
 388:../../BSP/LCD/lcd.c ****     }
 389:../../BSP/LCD/lcd.c **** }
 390:../../BSP/LCD/lcd.c **** 
 391:../../BSP/LCD/lcd.c **** /**
 392:../../BSP/LCD/lcd.c ****  * @brief       Ś°ęŚÖÖŚģěŚŅÉŚúÜ
 393:../../BSP/LCD/lcd.c ****  * @param       x,y  : ŚúÜšł≠ŚŅÉŚĚźś†á
 394:../../BSP/LCD/lcd.c ****  * @param       r    : ŚćäŚĺĄ
 395:../../BSP/LCD/lcd.c ****  * @param       color: ŚúÜÁöĄťĘúŤČ≤
 396:../../BSP/LCD/lcd.c ****  * @retval      śó†
 397:../../BSP/LCD/lcd.c ****  */
 398:../../BSP/LCD/lcd.c **** void lcd_fill_circle(uint16_t x, uint16_t y, uint16_t r, uint32_t color)
 399:../../BSP/LCD/lcd.c **** {
 400:../../BSP/LCD/lcd.c ****     uint32_t i;
 401:../../BSP/LCD/lcd.c ****     uint32_t imax = ((uint32_t)r * 707) / 1000 + 1;
 402:../../BSP/LCD/lcd.c ****     uint32_t sqmax = (uint32_t)r * (uint32_t)r + (uint32_t)r / 2;
 403:../../BSP/LCD/lcd.c ****     uint32_t xr = r;
 404:../../BSP/LCD/lcd.c **** 
 405:../../BSP/LCD/lcd.c ****     lcd_draw_hline(x - r, y, 2 * r, color);
 406:../../BSP/LCD/lcd.c **** 
 407:../../BSP/LCD/lcd.c ****     for (i = 1; i <= imax; i++)
 408:../../BSP/LCD/lcd.c ****     {
 409:../../BSP/LCD/lcd.c ****         if ((i * i + xr * xr) > sqmax)
 410:../../BSP/LCD/lcd.c ****         {
 411:../../BSP/LCD/lcd.c ****             /* draw lines from outside */
 412:../../BSP/LCD/lcd.c ****             if (xr > imax)
 413:../../BSP/LCD/lcd.c ****             {
 414:../../BSP/LCD/lcd.c ****                 lcd_draw_hline (x - i + 1, y + xr, 2 * (i - 1), color);
 415:../../BSP/LCD/lcd.c ****                 lcd_draw_hline (x - i + 1, y - xr, 2 * (i - 1), color);
 416:../../BSP/LCD/lcd.c ****             }
 417:../../BSP/LCD/lcd.c **** 
 418:../../BSP/LCD/lcd.c ****             xr--;
 419:../../BSP/LCD/lcd.c ****         }
 420:../../BSP/LCD/lcd.c **** 
 421:../../BSP/LCD/lcd.c ****         /* draw lines from inside (center) */
 422:../../BSP/LCD/lcd.c ****         lcd_draw_hline(x - xr, y + i, 2 * xr, color);
 423:../../BSP/LCD/lcd.c ****         lcd_draw_hline(x - xr, y - i, 2 * xr, color);
 424:../../BSP/LCD/lcd.c ****     }
 425:../../BSP/LCD/lcd.c **** }
 426:../../BSP/LCD/lcd.c **** 
