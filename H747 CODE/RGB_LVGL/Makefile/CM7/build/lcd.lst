 269:../../BSP/LCD/lcd.c ****  * @param       x2,y2: ÁĽąÁāĻŚĚźś†á
 270:../../BSP/LCD/lcd.c ****  * @param       color: ÁļŅÁöĄťĘúŤČ≤
 271:../../BSP/LCD/lcd.c ****  * @retval      śó†
 272:../../BSP/LCD/lcd.c ****  */
 273:../../BSP/LCD/lcd.c **** void lcd_draw_line(uint16_t x1, uint16_t y1, uint16_t x2, uint16_t y2, uint32_t color)
 274:../../BSP/LCD/lcd.c **** {
 275:../../BSP/LCD/lcd.c ****     uint16_t t;
 276:../../BSP/LCD/lcd.c ****     int xerr = 0, yerr = 0, delta_x, delta_y, distance;
 277:../../BSP/LCD/lcd.c ****     int incx, incy, row, col;
 278:../../BSP/LCD/lcd.c ****     delta_x = x2 - x1;                 /* Ťģ°ÁģóŚĚźś†áŚĘěťáŹ */
 279:../../BSP/LCD/lcd.c ****     delta_y = y2 - y1;
 280:../../BSP/LCD/lcd.c ****     row = x1;
 281:../../BSP/LCD/lcd.c ****     col = y1;
 282:../../BSP/LCD/lcd.c **** 
 283:../../BSP/LCD/lcd.c ****     if (delta_x > 0) incx = 1;         /* ŤģĺÁĹģŚćēś≠•śĖĻŚźĎ */
 284:../../BSP/LCD/lcd.c ****     else if (delta_x == 0) incx = 0;   /* ŚěāÁõīÁļŅ */
 285:../../BSP/LCD/lcd.c ****     else
 286:../../BSP/LCD/lcd.c ****     {
 287:../../BSP/LCD/lcd.c ****         incx = -1;
 288:../../BSP/LCD/lcd.c ****         delta_x = -delta_x;
 289:../../BSP/LCD/lcd.c ****     }
 290:../../BSP/LCD/lcd.c **** 
 291:../../BSP/LCD/lcd.c ****     if (delta_y > 0) incy = 1;
 292:../../BSP/LCD/lcd.c ****     else if (delta_y == 0) incy = 0;   /* śįīŚĻ≥ÁļŅ */
 293:../../BSP/LCD/lcd.c ****     else
 294:../../BSP/LCD/lcd.c ****     {
 295:../../BSP/LCD/lcd.c ****         incy = -1;
 296:../../BSP/LCD/lcd.c ****         delta_y = -delta_y;
 297:../../BSP/LCD/lcd.c ****     }
 298:../../BSP/LCD/lcd.c **** 
 299:../../BSP/LCD/lcd.c ****     if ( delta_x > delta_y) distance = delta_x; /* ťÄČŚŹĖŚüļśú¨ŚĘěťáŹŚĚźś†áŤĹī */
 300:../../BSP/LCD/lcd.c ****     else distance = delta_y;
 301:../../BSP/LCD/lcd.c **** 
 302:../../BSP/LCD/lcd.c ****     for (t = 0; t <= distance + 1; t++ )        /* ÁĒĽÁļŅŤĺďŚáļ */
 303:../../BSP/LCD/lcd.c ****     {
 304:../../BSP/LCD/lcd.c ****         lcd_draw_point(row, col, color);        /* ÁĒĽÁāĻ */
 305:../../BSP/LCD/lcd.c ****         xerr += delta_x ;
 306:../../BSP/LCD/lcd.c ****         yerr += delta_y ;
 307:../../BSP/LCD/lcd.c **** 
 308:../../BSP/LCD/lcd.c ****         if (xerr > distance)
 309:../../BSP/LCD/lcd.c ****         {
 310:../../BSP/LCD/lcd.c ****             xerr -= distance;
 311:../../BSP/LCD/lcd.c ****             row += incx;
 312:../../BSP/LCD/lcd.c ****         }
 313:../../BSP/LCD/lcd.c **** 
 314:../../BSP/LCD/lcd.c ****         if (yerr > distance)
 315:../../BSP/LCD/lcd.c ****         {
 316:../../BSP/LCD/lcd.c ****             yerr -= distance;
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccA8hrCI.s 			page 7


 317:../../BSP/LCD/lcd.c ****             col += incy;
 318:../../BSP/LCD/lcd.c ****         }
 319:../../BSP/LCD/lcd.c ****     }
 320:../../BSP/LCD/lcd.c **** }
