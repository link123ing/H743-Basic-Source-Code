 151:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** bool lv_draw_sw_register_blend_handler(lv_draw_sw_custom_blend_handler_t * handler)
 152:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** {
 153:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_sw_custom_blend_handler_t * existing_handler = NULL;
 154:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_sw_custom_blend_handler_t * new_handler = NULL;
 155:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 156:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     // Check if a handler is already registered for the color format
 157:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     LV_LL_READ(&LV_GLOBAL_DEFAULT()->draw_sw_blend_handler_ll, existing_handler) {
 158:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         if(existing_handler->dest_cf == handler->dest_cf) {
 159:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             new_handler = existing_handler;
 160:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             break;
 161:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         }
