 166:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         if(new_handler == NULL) {
 167:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             LV_ASSERT_MALLOC(new_handler);
 168:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             return false;
 169:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         }
 170:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 171:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 172:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_memcpy(new_handler, handler, sizeof(lv_draw_sw_custom_blend_handler_t));
