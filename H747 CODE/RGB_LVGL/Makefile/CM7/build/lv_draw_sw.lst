 250:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** static int32_t dispatch(lv_draw_unit_t * draw_unit, lv_layer_t * layer)
 251:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** {
 252:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     LV_PROFILER_DRAW_BEGIN;
 253:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_sw_unit_t * draw_sw_unit = (lv_draw_sw_unit_t *) draw_unit;
 254:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 255:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** #if LV_USE_OS
 256:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     uint32_t i;
 257:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     uint32_t taken_cnt = 0;
 258:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     /* All idle (couldn't take any tasks): return LV_DRAW_UNIT_IDLE;
 259:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****      * All busy: return 0; as 0 tasks were taken
 260:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****      * Otherwise return taken_cnt;
 261:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****      */
 262:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 263:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     /*If at least one is busy, it's not all idle*/
 264:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     bool all_idle = true;
 265:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     for(i = 0; i < LV_DRAW_SW_DRAW_UNIT_CNT; i++) {
 266:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         if(draw_sw_unit->thread_dscs[i].task_act) {
 267:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             all_idle = false;
 268:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             break;
 269:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         }
 270:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 271:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 272:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     lv_draw_task_t * t = NULL;
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccysLnre.s 			page 8


 273:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     for(i = 0; i < LV_DRAW_SW_DRAW_UNIT_CNT; i++) {
 274:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         lv_draw_sw_thread_dsc_t * thread_dsc = &draw_sw_unit->thread_dscs[i];
 275:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 276:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Do nothing if busy*/
 277:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         if(thread_dsc->task_act) continue;
 278:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 279:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Find an available task. Start from the previously taken task.*/
 280:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         t = lv_draw_get_next_available_task(layer, t, DRAW_UNIT_ID_SW);
 281:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 282:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         /*If there is not available task don't try other threads as there won't be available
 283:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****          *tasks for then either*/
 284:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         if(t == NULL) {
 285:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             LV_PROFILER_DRAW_END;
 286:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             if(all_idle) return LV_DRAW_UNIT_IDLE;  /*Couldn't start rendering*/
 287:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****             else return taken_cnt;
 288:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         }
 289:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 290:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Allocate a buffer if not done yet.*/
 291:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         void * buf = lv_draw_layer_alloc_buf(layer);
 292:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Do not return is failed. The other thread might already have a buffer can do something. *
 293:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         if(buf == NULL) continue;
 294:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 295:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Take the task*/
 296:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         all_idle = false;
 297:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         taken_cnt++;
 298:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         t->state = LV_DRAW_TASK_STATE_IN_PROGRESS;
 299:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         thread_dsc->task_act = t;
 300:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 301:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         /*Let the render thread work*/
 302:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         if(thread_dsc->inited) lv_thread_sync_signal(&thread_dsc->sync);
 303:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 304:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 305:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     if(all_idle) return LV_DRAW_UNIT_IDLE;  /*Couldn't start rendering*/
 306:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     else return taken_cnt;
 307:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
 308:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** #else
 309:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     /*Return immediately if it's busy with draw task*/
 310:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     if(draw_sw_unit->task_act) {
 311:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         LV_PROFILER_DRAW_END;
 312:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****         return 0;
 313:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c ****     }
 314:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw.c **** 
