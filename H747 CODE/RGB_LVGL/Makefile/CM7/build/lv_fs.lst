 170:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_fs.c ****         if(file_p->drv->cache_size != LV_FS_CACHE_FROM_BUFFER && file_p->cache->buffer) {
 171:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_fs.c ****             lv_free(file_p->cache->buffer);
 172:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_fs.c ****         }
 173:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_fs.c **** 
 174:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_fs.c ****         lv_free(file_p->cache);
