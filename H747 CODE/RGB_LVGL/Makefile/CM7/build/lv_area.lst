  69:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** uint32_t lv_area_get_size(const lv_area_t * area_p)
  70:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** {
