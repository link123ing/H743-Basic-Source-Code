  94:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** bool lv_area_intersect(lv_area_t * res_p, const lv_area_t * a1_p, const lv_area_t * a2_p)
  95:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** {
  96:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Get the smaller area from 'a1_p' and 'a2_p'*/
  97:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     res_p->x1 = LV_MAX(a1_p->x1, a2_p->x1);
  98:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     res_p->y1 = LV_MAX(a1_p->y1, a2_p->y1);
  99:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     res_p->x2 = LV_MIN(a1_p->x2, a2_p->x2);
 100:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     res_p->y2 = LV_MIN(a1_p->y2, a2_p->y2);
 101:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 102:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*If x1 or y1 greater than x2 or y2 then the areas union is empty*/
 103:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     bool union_ok = true;
 104:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if((res_p->x1 > res_p->x2) || (res_p->y1 > res_p->y2)) {
 105:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         union_ok = false;
 106:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     }
 107:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 108:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     return union_ok;
 109:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** }
 110:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 111:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** int8_t lv_area_diff(lv_area_t res_p[], const lv_area_t * a1_p, const lv_area_t * a2_p)
 112:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** {
 113:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Areas have no common parts*/
 114:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if(!lv_area_is_on(a1_p, a2_p)) return -1;
 115:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 116:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*No remaining areas after removing common parts*/
 117:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if(lv_area_is_in(a1_p, a2_p, 0)) return 0;
 118:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 119:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Result counter*/
 120:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int8_t res_c = 0;
 121:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 122:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Get required information*/
 123:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     lv_area_t n;
 124:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t a1_w = lv_area_get_width(a1_p) - 1;
 125:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t a1_h = lv_area_get_height(a1_p) - 1;
 126:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 127:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Compute top rectangle*/
 128:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t th = a2_p->y1 - a1_p->y1;
 129:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if(th > 0) {
 130:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.x1 = a1_p->x1;
 131:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.y1 = a1_p->y1;
 132:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.x2 = a1_p->x2;
 133:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.y2 = a1_p->y1 + th - 1;
 134:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         res_p[res_c++] = n;
 135:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     }
 136:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 137:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Compute the bottom rectangle*/
 138:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t bh = a1_h - (a2_p->y2 - a1_p->y1);
 139:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if(bh > 0 && a2_p->y2 < a1_p->y2) {
 140:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.x1 = a1_p->x1;
 141:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.y1 = a2_p->y2 + 1;
 142:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.x2 = a1_p->x2;
 143:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.y2 = a2_p->y2 + bh;
 144:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         res_p[res_c++] = n;
 145:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     }
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccYc01Pv.s 			page 4


 146:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 147:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Compute side height*/
 148:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t y1 = a2_p->y1 > a1_p->y1 ? a2_p->y1 : a1_p->y1;
 149:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t y2 = a2_p->y2 < a1_p->y2 ? a2_p->y2 : a1_p->y2;
 150:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t sh = y2 - y1;
 151:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 152:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Compute the left rectangle*/
 153:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t lw = a2_p->x1 - a1_p->x1;
 154:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if(lw > 0 && sh >= 0) {
 155:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.x1 = a1_p->x1;
 156:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.y1 = y1;
 157:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.x2 = a1_p->x1 + lw - 1;
 158:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.y2 = y1 + sh;
 159:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         res_p[res_c++] = n;
 160:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     }
 161:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 162:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Compute the right rectangle*/
 163:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t rw = a1_w - (a2_p->x2 - a1_p->x1);
 164:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if(rw > 0 && sh >= 0) {
 165:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.x1 = a2_p->x2 + 1;
 166:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.y1 = y1;
 167:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.x2 = a2_p->x2 + rw;
 168:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         n.y2 = y1 + sh;
 169:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         res_p[res_c++] = n;
 170:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     }
 171:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 172:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     //Return number of results
 173:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     return res_c;
 174:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** }
 175:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 176:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** void lv_area_join(lv_area_t * a_res_p, const lv_area_t * a1_p, const lv_area_t * a2_p)
 177:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** {
 178:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     a_res_p->x1 = LV_MIN(a1_p->x1, a2_p->x1);
 179:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     a_res_p->y1 = LV_MIN(a1_p->y1, a2_p->y1);
 180:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     a_res_p->x2 = LV_MAX(a1_p->x2, a2_p->x2);
 181:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     a_res_p->y2 = LV_MAX(a1_p->y2, a2_p->y2);
 182:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** }
 183:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** 
 184:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** bool lv_area_is_point_on(const lv_area_t * a_p, const lv_point_t * p_p, int32_t radius)
 185:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c **** {
 186:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*First check the basic area*/
 187:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     bool is_on_rect = false;
 188:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if((p_p->x >= a_p->x1 && p_p->x <= a_p->x2) && ((p_p->y >= a_p->y1 && p_p->y <= a_p->y2))) {
 189:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         is_on_rect = true;
 190:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     }
 191:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if(!is_on_rect)
 192:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         return false;
 193:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     /*Now handle potential rounded rectangles*/
 194:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     if(radius <= 0) {
 195:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         /*No radius, it is within the rectangle*/
 196:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****         return true;
 197:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     }
 198:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_area.c ****     int32_t w = lv_area_get_width(a_p) / 2;
