 106:../../Middlewares/LVGL/GUI/lvgl/src/font/../misc/lv_text_private.h **** /**
 107:../../Middlewares/LVGL/GUI/lvgl/src/font/../misc/lv_text_private.h ****  * Test if char is break char or not (a text can broken here or not)
