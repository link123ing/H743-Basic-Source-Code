 168:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** void lv_dropdown_set_text(lv_obj_t * obj, const char * txt)
 169:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** {
 170:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 171:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     lv_dropdown_t * dropdown = (lv_dropdown_t *)obj;
 172:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     if(dropdown->text == txt) return;
 173:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** 
 174:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     dropdown->text = txt;
 175:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** 
 176:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     lv_obj_invalidate(obj);
 177:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** }
 178:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** 
 179:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** void lv_dropdown_set_options(lv_obj_t * obj, const char * options)
 180:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** {
 181:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     LV_ASSERT_OBJ(obj, MY_CLASS);
 182:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     LV_ASSERT_NULL(options);
 183:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** 
 184:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     lv_dropdown_t * dropdown = (lv_dropdown_t *)obj;
 185:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c **** 
 186:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     /*Count the '\n'-s to determine the number of options*/
 187:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     dropdown->option_cnt = 0;
 188:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     uint32_t i;
 189:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****     for(i = 0; options[i] != '\0'; i++) {
 190:../../Middlewares/LVGL/GUI/lvgl/src/widgets/dropdown/lv_dropdown.c ****         if(options[i] == '\n') dropdown->option_cnt++;
