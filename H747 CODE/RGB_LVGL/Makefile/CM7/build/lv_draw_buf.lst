 524:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****             lv_color_premultiply(&palette[i]);
 525:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****         }
 526:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****     }
 527:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****     else if(cf == LV_COLOR_FORMAT_ARGB8888) {
 528:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****         uint32_t h = draw_buf->header.h;
 529:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****         uint32_t w = draw_buf->header.w;
