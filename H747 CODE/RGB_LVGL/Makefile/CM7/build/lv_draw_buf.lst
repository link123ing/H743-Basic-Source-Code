 517:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c **** 
 518:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****     /*Premultiply color with alpha, do case by case by judging color format*/
 519:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****     lv_color_format_t cf = draw_buf->header.cf;
 520:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_buf.c ****     if(LV_COLOR_FORMAT_IS_INDEXED(cf)) {
