 179:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 180:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     /* For touchpad sometimes users don't set the last pressed coordinate on release.
 181:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****      * So be sure a coordinates are initialized to the last point */
 182:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     if(indev->type == LV_INDEV_TYPE_POINTER) {
 183:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         data->point.x = indev->pointer.last_raw_point.x;
 184:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         data->point.y = indev->pointer.last_raw_point.y;
 185:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     }
 186:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     /*Similarly set at least the last key in case of the user doesn't set it on release*/
 187:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     else if(indev->type == LV_INDEV_TYPE_KEYPAD) {
 188:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         data->key = indev->keypad.last_key;
 189:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     }
 190:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     /*For compatibility assume that used button was enter (encoder push)*/
 191:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     else if(indev->type == LV_INDEV_TYPE_ENCODER) {
 192:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         data->key = LV_KEY_ENTER;
 193:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     }
 194:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 195:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     if(indev->read_cb) {
 196:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         LV_TRACE_INDEV("calling indev_read_cb");
 197:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         indev->read_cb(indev, data);
 198:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     }
 199:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     else {
