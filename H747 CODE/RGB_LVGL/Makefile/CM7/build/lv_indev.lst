 698:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     /*Save the raw points so they can be used again in indev_read_core*/
 699:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     i->pointer.last_raw_point.x = data->point.x;
