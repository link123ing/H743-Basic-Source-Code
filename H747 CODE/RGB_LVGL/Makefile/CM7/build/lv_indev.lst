 701:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 702:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     if(disp->rotation == LV_DISPLAY_ROTATION_180 || disp->rotation == LV_DISPLAY_ROTATION_270) {
 703:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         data->point.x = disp->hor_res - data->point.x - 1;
 704:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         data->point.y = disp->ver_res - data->point.y - 1;
