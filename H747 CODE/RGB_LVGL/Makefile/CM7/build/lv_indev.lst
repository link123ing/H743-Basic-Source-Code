 211:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** void lv_indev_read(lv_indev_t * indev)
 212:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** {
 213:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     if(indev == NULL) return;
 214:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 215:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     LV_TRACE_INDEV("begin");
 216:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 217:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     indev_act = indev;
 218:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 219:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     /*Read and process all indevs*/
 220:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     if(indev->disp == NULL) return; /*Not assigned to any displays*/
 221:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 222:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     /*Handle reset query before processing the point*/
 223:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     indev_proc_reset_query_handler(indev);
 224:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 225:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     if(indev->enabled == 0) return;
 226:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     if(indev->disp->prev_scr != NULL) {
 227:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         LV_TRACE_INDEV("input blocked while screen animation active");
 228:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         return;
 229:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     }
 230:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 231:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     LV_PROFILER_INDEV_BEGIN;
 232:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 233:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     bool continue_reading;
 234:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     lv_indev_data_t data;
 235:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 236:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     do {
 237:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         /*Read the data*/
 238:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         indev_read_core(indev, &data);
 239:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         continue_reading = indev->mode != LV_INDEV_MODE_EVENT && data.continue_reading;
 240:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 241:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         /*The active object might be deleted even in the read function*/
 242:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         indev_proc_reset_query_handler(indev);
 243:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         indev_obj_act = NULL;
 244:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 245:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         indev->state = data.state;
 246:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 247:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         /*Save the last activity time*/
 248:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         if(indev->state == LV_INDEV_STATE_PRESSED) {
 249:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****             indev->disp->last_activity_time = lv_tick_get();
 250:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         }
 251:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         else if(indev->type == LV_INDEV_TYPE_ENCODER && data.enc_diff) {
 252:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****             indev->disp->last_activity_time = lv_tick_get();
 253:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         }
 254:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 255:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         if(indev->type == LV_INDEV_TYPE_POINTER) {
 256:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****             indev_pointer_proc(indev, &data);
 257:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         }
 258:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         else if(indev->type == LV_INDEV_TYPE_KEYPAD) {
 259:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****             indev_keypad_proc(indev, &data);
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccNl4PPv.s 			page 6


 260:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         }
 261:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         else if(indev->type == LV_INDEV_TYPE_ENCODER) {
 262:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****             indev_encoder_proc(indev, &data);
 263:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         }
 264:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         else if(indev->type == LV_INDEV_TYPE_BUTTON) {
 265:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****             indev_button_proc(indev, &data);
 266:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         }
 267:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         /*Handle reset query if it happened in during processing*/
 268:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****         indev_proc_reset_query_handler(indev);
 269:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     } while(continue_reading);
 270:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 271:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     /*End of indev processing, so no act indev*/
 272:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     indev_act     = NULL;
 273:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     indev_obj_act = NULL;
 274:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** 
 275:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     LV_TRACE_INDEV("finished");
 276:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c ****     LV_PROFILER_INDEV_END;
 277:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev.c **** }
