 127:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void lv_ll_remove(lv_ll_t * ll_p, void * node_p)
 128:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 129:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(ll_p == NULL) return;
 130:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 131:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(lv_ll_get_head(ll_p) == node_p) {
 132:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         /*The new head will be the node after 'node_p'*/
 133:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         ll_p->head = lv_ll_get_next(ll_p, node_p);
 134:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(ll_p->head == NULL) {
 135:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             ll_p->tail = NULL;
 136:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 137:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         else {
 138:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             node_set_prev(ll_p, ll_p->head, NULL);
 139:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 140:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
 141:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     else if(lv_ll_get_tail(ll_p) == node_p) {
 142:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         /*The new tail will be the node before 'node_p'*/
 143:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         ll_p->tail = lv_ll_get_prev(ll_p, node_p);
 144:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(ll_p->tail == NULL) {
 145:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             ll_p->head = NULL;
ARM GAS  C:\Users\28576\AppData\Local\Temp\cclElusE.s 			page 4


 146:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 147:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         else {
 148:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             node_set_next(ll_p, ll_p->tail, NULL);
 149:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 150:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
 151:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     else {
