 113:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_new, ll_p->tail); /*The prev. before new is the old tail*/
 114:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(ll_p->tail != NULL) {                /*If there is old tail then the new comes after it*
 115:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             node_set_next(ll_p, ll_p->tail, n_new);
 116:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 117:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 118:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         ll_p->tail = n_new;      /*Set the new tail in the dsc.*/
 119:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(ll_p->head == NULL) { /*If there is no head (1. node) set the head too*/
 120:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             ll_p->head = n_new;
 121:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 122:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
 123:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 124:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return n_new;
 125:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
