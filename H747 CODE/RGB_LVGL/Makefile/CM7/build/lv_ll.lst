 203:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 204:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(ll_new_p->tail != NULL) { /*If there is old tail then after it goes the new*/
 205:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             node_set_next(ll_new_p, ll_new_p->tail, node);
 206:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 207:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 208:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         ll_new_p->tail = node;       /*Set the new tail in the dsc.*/
 209:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(ll_new_p->head == NULL) { /*If there is no head (first node) set the head too*/
 210:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             ll_new_p->head = node;
 211:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 212:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
 213:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
 214:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 215:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void * lv_ll_get_head(const lv_ll_t * ll_p)
 216:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 217:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(ll_p == NULL) return NULL;
 218:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return ll_p->head;
 219:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
 220:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 221:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void * lv_ll_get_tail(const lv_ll_t * ll_p)
 222:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 223:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(ll_p == NULL) return NULL;
 224:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return ll_p->tail;
 225:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
 226:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 227:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void * lv_ll_get_next(const lv_ll_t * ll_p, const void * n_act)
 228:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 229:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     /*Pointer to the next node is stored in the end of this node.
 230:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****      *Go there and return the address found there*/
 231:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     const lv_ll_node_t * n_act_d = n_act;
 232:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     n_act_d += LL_NEXT_P_OFFSET(ll_p);
 233:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return *((lv_ll_node_t **)n_act_d);
 234:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
 235:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 236:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void * lv_ll_get_prev(const lv_ll_t * ll_p, const void * n_act)
 237:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 238:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     /*Pointer to the prev. node is stored in the end of this node.
 239:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****      *Go there and return the address found there*/
 240:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     const lv_ll_node_t * n_act_d = n_act;
 241:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     n_act_d += LL_PREV_P_OFFSET(ll_p);
 242:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return *((lv_ll_node_t **)n_act_d);
 243:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
 244:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 245:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** uint32_t lv_ll_get_len(const lv_ll_t * ll_p)
 246:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 247:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     uint32_t len = 0;
 248:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     void * node;
 249:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 250:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     for(node = lv_ll_get_head(ll_p); node != NULL; node = lv_ll_get_next(ll_p, node)) {
 251:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         len++;
 252:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
 253:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 254:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return len;
 255:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
 256:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 257:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void lv_ll_move_before(lv_ll_t * ll_p, void * n_act, void * n_after)
 258:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 259:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(n_act == n_after) return; /*Can't move before itself*/
ARM GAS  C:\Users\28576\AppData\Local\Temp\cclElusE.s 			page 6


 260:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 261:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     void * n_before;
 262:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(n_after != NULL)
 263:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         n_before = lv_ll_get_prev(ll_p, n_after);
 264:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     else
 265:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         n_before = lv_ll_get_tail(ll_p); /*if `n_after` is NULL `n_act` should be the new tail*/
 266:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 267:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(n_act == n_before) return; /*Already before `n_after`*/
 268:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 269:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     /*It's much easier to remove from the list and add again*/
 270:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     lv_ll_remove(ll_p, n_act);
 271:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 272:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     /*Add again by setting the prev. and next nodes*/
 273:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     node_set_next(ll_p, n_before, n_act);
 274:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     node_set_prev(ll_p, n_act, n_before);
 275:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     node_set_prev(ll_p, n_after, n_act);
 276:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     node_set_next(ll_p, n_act, n_after);
 277:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 278:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     /*If `n_act` was moved before NULL then it become the new tail*/
 279:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(n_after == NULL) ll_p->tail = n_act;
 280:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 281:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     /*If `n_act` was moved before `NULL` then it's the new head*/
 282:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(n_before == NULL) ll_p->head = n_act;
 283:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
 284:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 285:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** bool lv_ll_is_empty(lv_ll_t * ll_p)
 286:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 287:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(ll_p == NULL) return true;
 288:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 289:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(ll_p->head == NULL && ll_p->tail == NULL) return true;
 290:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 291:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return false;
 292:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
