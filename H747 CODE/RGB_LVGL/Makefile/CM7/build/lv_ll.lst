 160:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void lv_ll_clear_custom(lv_ll_t * ll_p, void(*cleanup)(void *))
 161:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
 162:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     void * i;
 163:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     void * i_next;
 164:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 165:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     i      = lv_ll_get_head(ll_p);
 166:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     i_next = NULL;
 167:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 168:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     while(i != NULL) {
 169:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         i_next = lv_ll_get_next(ll_p, i);
 170:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(cleanup == NULL) {
 171:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             lv_ll_remove(ll_p, i);
 172:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             lv_free(i);
 173:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 174:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         else {
 175:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             cleanup(i);
 176:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
 177:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         i = i_next;
 178:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
 179:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
