  42:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void lv_ll_init(lv_ll_t * ll_p, uint32_t node_size)
  43:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
  44:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     ll_p->head = NULL;
  45:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     ll_p->tail = NULL;
  46:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** #ifdef LV_ARCH_64
  47:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     /*Round the size up to 8*/
  48:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     node_size = (node_size + 7) & (~0x7);
  49:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** #else
  50:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     /*Round the size up to 4*/
  51:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     node_size = (node_size + 3) & (~0x3);
  52:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** #endif
  53:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  54:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     ll_p->n_size = node_size;
  55:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
  56:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  57:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void * lv_ll_ins_head(lv_ll_t * ll_p)
  58:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
  59:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     lv_ll_node_t * n_new;
  60:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  61:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     n_new = lv_malloc(ll_p->n_size + LL_NODE_META_SIZE);
  62:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  63:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(n_new != NULL) {
  64:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_new, NULL);       /*No prev. before the new head*/
  65:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_p, n_new, ll_p->head); /*After new comes the old head*/
  66:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  67:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(ll_p->head != NULL) { /*If there is old head then before it goes the new*/
  68:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             node_set_prev(ll_p, ll_p->head, n_new);
  69:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
  70:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  71:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         ll_p->head = n_new;      /*Set the new head in the dsc.*/
  72:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(ll_p->tail == NULL) { /*If there is no tail (1. node) set the tail too*/
  73:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****             ll_p->tail = n_new;
  74:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         }
  75:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
  76:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  77:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return n_new;
  78:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** }
  79:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  80:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** void * lv_ll_ins_prev(lv_ll_t * ll_p, void * n_act)
  81:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** {
  82:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     lv_ll_node_t * n_new;
  83:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  84:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(NULL == ll_p || NULL == n_act) return NULL;
  85:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  86:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     if(lv_ll_get_head(ll_p) == n_act) {
  87:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         n_new = lv_ll_ins_head(ll_p);
  88:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(n_new == NULL) return NULL;
ARM GAS  C:\Users\28576\AppData\Local\Temp\cclElusE.s 			page 3


  89:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
  90:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     else {
  91:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         n_new = lv_malloc(ll_p->n_size + LL_NODE_META_SIZE);
  92:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         if(n_new == NULL) return NULL;
  93:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
  94:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         lv_ll_node_t * n_prev;
  95:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         n_prev = lv_ll_get_prev(ll_p, n_act);
  96:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_p, n_prev, n_new);
  97:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_new, n_prev);
  98:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         node_set_prev(ll_p, n_act, n_new);
  99:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****         node_set_next(ll_p, n_new, n_act);
 100:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     }
 101:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c **** 
 102:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_ll.c ****     return n_new;
