 544:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* This version rounds up to the next block size (for allocations) */
 545:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** static void mapping_search(size_t size, int * fli, int * sli)
 546:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** {
 547:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     if(size >= SMALL_BLOCK_SIZE) {
 548:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****         const size_t round = (1 << (tlsf_fls_sizet(size) - SL_INDEX_COUNT_LOG2)) - 1;
 549:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****         size += round;
 550:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     }
 551:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     mapping_insert(size, fli, sli);
