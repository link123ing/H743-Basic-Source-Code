 286:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 287:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 288:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Static assertion mechanism.
 289:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 290:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 291:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define _tlsf_glue2(x, y) x ## y
 292:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define _tlsf_glue(x, y) _tlsf_glue2(x, y)
 293:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define tlsf_static_assert(exp) \
 294:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     typedef char _tlsf_glue(static_assert, __LINE__) [(exp) ? 1 : -1]
 295:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 296:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* This code has been tested on 32- and 64-bit (LP/LLP) architectures. */
 297:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(sizeof(int) * CHAR_BIT == 32);
 298:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(sizeof(size_t) * CHAR_BIT >= 32);
 299:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(sizeof(size_t) * CHAR_BIT <= 64);
 300:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 301:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* SL_INDEX_COUNT must be <= number of bits in sl_bitmap's storage type. */
 302:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(sizeof(unsigned int) * CHAR_BIT >= SL_INDEX_COUNT);
 303:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 304:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* Ensure we've properly tuned our sizes. */
 305:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_static_assert(ALIGN_SIZE == SMALL_BLOCK_SIZE / SL_INDEX_COUNT);
 306:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 307:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 308:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Data structures and associated constants.
 309:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 310:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 311:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 312:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Block header structure.
 313:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** **
 314:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** There are several implementation subtleties involved:
 315:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - The prev_phys_block field is only valid if the previous block is free.
 316:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - The prev_phys_block field is actually stored at the end of the
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccJyLlrx.s 			page 7


 317:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** **   previous block. It appears at the beginning of this structure only to
 318:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** **   simplify the implementation.
 319:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - The next_free / prev_free fields are only valid if the block is free.
 320:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 321:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** typedef struct block_header_t {
 322:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Points to the previous physical block. */
 323:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     struct block_header_t * prev_phys_block;
 324:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 325:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* The size of this block, excluding the block header. */
 326:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     size_t size;
 327:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 328:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Next and previous free blocks. */
 329:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     struct block_header_t * next_free;
 330:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     struct block_header_t * prev_free;
 331:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** } block_header_t;
 332:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 333:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 334:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Since block sizes are always at least a multiple of 4, the two least
 335:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** significant bits of the size field are used to store the block status:
 336:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - bit 0: whether block is busy or free
 337:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** - bit 1: whether previous block is busy or free
 338:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 339:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_header_free_bit = 1 << 0;
 340:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_header_prev_free_bit = 1 << 1;
 341:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 342:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 343:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** The size of the block header exposed to used blocks is the size field.
 344:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** The prev_phys_block field is stored *inside* the previous free block.
 345:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 346:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_header_overhead = sizeof(size_t);
 347:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 348:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* User data starts directly after the size field in a used block. */
 349:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_start_offset =
 350:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     offsetof(block_header_t, size) + sizeof(size_t);
 351:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 352:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
 353:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** A free block must be large enough to store its header minus the size of
 354:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** the prev_phys_block field, and no larger than the number of addressable
 355:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** bits for FL_INDEX.
 356:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
 357:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_size_min =
 358:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     sizeof(block_header_t) - sizeof(block_header_t *);
 359:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** static const size_t block_size_max = tlsf_cast(size_t, 1) << FL_INDEX_MAX;
 360:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 361:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* The TLSF control structure. */
 362:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** typedef struct control_t {
 363:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Empty lists point at this block to indicate they are free. */
 364:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     block_header_t block_null;
 365:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 366:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Bitmaps for free lists. */
 367:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     unsigned int fl_bitmap;
 368:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     unsigned int sl_bitmap[FL_INDEX_COUNT];
 369:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 370:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* Head of free lists. */
 371:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     block_header_t * blocks[FL_INDEX_COUNT][SL_INDEX_COUNT];
 372:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** } control_t;
