 192:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** }
 193:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 194:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
 195:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 196:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* Possibly 64-bit version of tlsf_fls. */
 197:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (TLSF_64BIT)
 198:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_decl int tlsf_fls_sizet(size_t size)
 199:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** {
 200:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     int high = (int)(size >> 32);
 201:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     int bits = 0;
 202:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     if(high) {
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccJyLlrx.s 			page 5


 203:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****         bits = 32 + tlsf_fls(high);
 204:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     }
 205:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     else {
