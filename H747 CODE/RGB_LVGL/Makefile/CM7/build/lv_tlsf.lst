 221:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* Public constants: may be modified. */
 222:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** typedef enum {
 223:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* log2 of number of linear subdivisions of block sizes. Larger
 224:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** values require more memory in the control structure. Values of
 225:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** 4 or 5 are typical.
 226:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     */
 227:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     SL_INDEX_COUNT_LOG2 = 5,
 228:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** } tlsf_public;
 229:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 230:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* Private constants: do not modify. */
 231:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** typedef enum {
 232:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (TLSF_64BIT)
 233:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* All allocation sizes and addresses are aligned to 8 bytes. */
 234:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ALIGN_SIZE_LOG2 = 3,
 235:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #else
 236:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /* All allocation sizes and addresses are aligned to 4 bytes. */
 237:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ALIGN_SIZE_LOG2 = 2,
 238:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
 239:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ALIGN_SIZE = (1 << ALIGN_SIZE_LOG2),
 240:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 241:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /*
 242:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** We support allocations of sizes up to (1 << FL_INDEX_MAX) bits.
 243:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** However, because we linearly subdivide the second-level lists, and
 244:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** our minimum size granularity is 4 bytes, it doesn't make sense to
 245:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** create first-level lists for sizes smaller than SL_INDEX_COUNT * 4,
 246:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** or (1 << (SL_INDEX_COUNT_LOG2 + 2)) bytes, as there we will be
 247:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** trying to split size ranges into more slots than we have available.
 248:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** Instead, we calculate the minimum threshold size, and place all
 249:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** blocks below that size into the 0th first-level list.
 250:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     */
 251:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
 252:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (TLSF_MAX_POOL_SIZE)
 253:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_MAX = TLSF_LOG2_CEIL(TLSF_MAX_POOL_SIZE),
 254:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #elif defined (TLSF_64BIT)
 255:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     /*
 256:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** TODO: We can increase this to support larger sizes, at the expense
 257:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     ** of more overhead in the TLSF structure.
 258:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     */
 259:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_MAX = 32,
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccJyLlrx.s 			page 6


 260:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #else
 261:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_MAX = 30,
 262:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
 263:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     SL_INDEX_COUNT = (1 << SL_INDEX_COUNT_LOG2),
 264:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_SHIFT = (SL_INDEX_COUNT_LOG2 + ALIGN_SIZE_LOG2),
 265:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     FL_INDEX_COUNT = (FL_INDEX_MAX - FL_INDEX_SHIFT + 1),
