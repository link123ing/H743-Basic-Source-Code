  24:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  25:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  26:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Architecture-specific bit manipulation routines.
  27:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** **
  28:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** TLSF achieves O(1) cost for malloc and free operations by limiting
  29:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** the search for a free block to a free list of guaranteed size
  30:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** adequate to fulfill the request, combined with efficient free list
  31:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** queries using bitmasks and architecture-specific bit-manipulation
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccJyLlrx.s 			page 2


  32:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** routines.
  33:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** **
  34:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Most modern processors provide instructions to count leading zeroes
  35:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** in a word, find the lowest and highest set bit, etc. These
  36:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** specific implementations will be used when available, falling back
  37:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** to a reasonably efficient generic implementation.
  38:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** **
  39:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** NOTE: TLSF spec relies on ffs/fls returning value 0..31.
  40:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** ffs/fls return 1-32 by default, returning 0 for error.
  41:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  42:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  43:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  44:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Detect whether or not we are building for a 32- or 64-bit (LP/LLP)
  45:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** architecture. There is no reliable portable method at compile-time.
  46:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  47:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (__alpha__) || defined (__ia64__) || defined (__x86_64__) \
  48:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     || defined (_WIN64) || defined (__LP64__) || defined (__LLP64__)
  49:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     #define TLSF_64BIT
  50:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
  51:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  52:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  53:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Returns one plus the index of the most significant 1-bit of n,
  54:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** or if n is zero, returns zero.
  55:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  56:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #ifdef TLSF_64BIT
  57:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     #define TLSF_FLS(n) ((n) & 0xffffffff00000000ull ? 32 + TLSF_FLS32((size_t)(n) >> 32) : TLSF_FL
  58:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #else
  59:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     #define TLSF_FLS(n) TLSF_FLS32(n)
  60:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
  61:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  62:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS32(n) ((n) & 0xffff0000 ? 16 + TLSF_FLS16((n) >> 16) : TLSF_FLS16(n))
  63:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS16(n) ((n) & 0xff00     ?  8 + TLSF_FLS8 ((n) >>  8) : TLSF_FLS8 (n))
  64:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS8(n)  ((n) & 0xf0       ?  4 + TLSF_FLS4 ((n) >>  4) : TLSF_FLS4 (n))
  65:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS4(n)  ((n) & 0xc        ?  2 + TLSF_FLS2 ((n) >>  2) : TLSF_FLS2 (n))
  66:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS2(n)  ((n) & 0x2        ?  1 + TLSF_FLS1 ((n) >>  1) : TLSF_FLS1 (n))
  67:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_FLS1(n)  ((n) & 0x1        ?  1 : 0)
  68:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  69:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  70:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Returns round up value of log2(n).
  71:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Note: it is used at compile time.
  72:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  73:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #define TLSF_LOG2_CEIL(n) ((n) & (n - 1) ? TLSF_FLS(n) : TLSF_FLS(n) - 1)
  74:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  75:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /*
  76:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** gcc 3.4 and above have builtin support, specialized for architecture.
  77:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** ** Some compilers masquerade as gcc; patchlevel test filters them out.
  78:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** */
  79:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (__GNUC__) && (__GNUC__ > 3 || (__GNUC__ == 3 && __GNUC_MINOR__ >= 4)) \
  80:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     && defined (__GNUC_PATCHLEVEL__)
  81:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  82:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #if defined (__SNC__)
  83:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** /* SNC for PlayStation 3. */
  84:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  85:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_decl int tlsf_ffs(unsigned int word)
  86:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** {
  87:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     const unsigned int reverse = word & (~word + 1);
  88:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     const int bit = 32 - __builtin_clz(reverse);
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccJyLlrx.s 			page 3


  89:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     return bit - 1;
  90:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** }
  91:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  92:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #else
  93:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  94:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** tlsf_decl int tlsf_ffs(unsigned int word)
  95:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** {
  96:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c ****     return __builtin_ffs(word) - 1;
  97:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** }
  98:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** 
  99:../../Middlewares/LVGL/GUI/lvgl/src/stdlib/builtin/lv_tlsf.c **** #endif
