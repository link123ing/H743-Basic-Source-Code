 699:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****         if(obj->styles[i].is_local &&
 700:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****            obj->styles[i].selector == selector) {
 701:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****             return (lv_style_t *)obj->styles[i].style;
 702:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****         }
