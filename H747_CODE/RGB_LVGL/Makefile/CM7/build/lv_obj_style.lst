 721:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****     obj->styles[i].is_local = 1;
 722:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****     obj->styles[i].selector = selector;
 723:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****     return (lv_style_t *)obj->styles[i].style;
 724:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c **** }
