 705:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****     obj->style_cnt++;
 706:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****     LV_ASSERT(obj->style_cnt != 0);
 707:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****     obj->styles = lv_realloc(obj->styles, obj->style_cnt * sizeof(lv_obj_style_t));
 708:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_style.c ****     LV_ASSERT_MALLOC(obj->styles);
