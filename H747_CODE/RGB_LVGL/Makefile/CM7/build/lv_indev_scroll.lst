 645:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 646:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     /*Scroll back to the edge if required*/
 647:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(!lv_obj_has_flag(scroll_obj, LV_OBJ_FLAG_SCROLL_ELASTIC)) {
 648:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*
 649:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          * If the scrolling object does not set the `LV_OBJ_FLAG_SCROLL_ELASTIC` flag,
 650:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          * make sure that `diff` will not cause the scroll to exceed the `start` or `end` boundary 
 651:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          * If the content has exceeded the boundary due to external factors like `LV_SCROLL_SNAP_CE
 652:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          * then respect the current position instead of going straight back to 0.
 653:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          */
 654:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         const int32_t scroll_ended = diff > 0 ? scroll_start : scroll_end;
 655:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(scroll_ended < 0) diff = 0;
 656:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         else if(scroll_ended - diff < 0) diff = scroll_ended;
 657:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     }
 658:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     /*Handle elastic scrolling*/
 659:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     else {
 660:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 661:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         lv_scroll_snap_t snap;
 662:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         snap = dir == LV_DIR_HOR ? lv_obj_get_scroll_snap_x(scroll_obj) : lv_obj_get_scroll_snap_y(
 663:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 664:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*Without snapping just scale down the diff when scrolled out*/
 665:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(snap == LV_SCROLL_SNAP_NONE) {
 666:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             if(scroll_end < 0 || scroll_start < 0) {
 667:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****                 /*Rounding*/
 668:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****                 if(diff < 0) diff -= ELASTIC_SLOWNESS_FACTOR / 2;
 669:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****                 if(diff > 0) diff += ELASTIC_SLOWNESS_FACTOR / 2;
