 677:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*With snapping the widget is scrolled out if there are no more snap points
 678:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          *at least in one direction (start or end)*/
 679:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         bool has_start_snap;
 680:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         bool has_end_snap;
 681:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         has_more_snap_points(scroll_obj, dir, &has_start_snap, &has_end_snap);
 682:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 683:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(!has_start_snap || !has_end_snap) {
 684:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             /*Rounding*/
 685:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             if(diff < 0) diff -= ELASTIC_SLOWNESS_FACTOR / 2;
 686:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             if(diff > 0) diff += ELASTIC_SLOWNESS_FACTOR / 2;
 687:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             return diff / ELASTIC_SLOWNESS_FACTOR;
 688:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 689:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         else {
