  66:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     /*Set new position or scroll if the vector is not zero*/
  67:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int16_t angle = 0;
  68:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int16_t scale_x = 256;
  69:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int16_t scale_y = 256;
  70:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     lv_obj_t * parent = scroll_obj;
  71:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     while(parent) {
  72:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         angle += lv_obj_get_style_transform_rotation(parent, 0);
  73:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int32_t zoom_act_x = lv_obj_get_style_transform_scale_x_safe(parent, 0);
  74:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int32_t zoom_act_y = lv_obj_get_style_transform_scale_y_safe(parent, 0);
  75:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         scale_x = (scale_x * zoom_act_x) >> 8;
  76:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         scale_y = (scale_y * zoom_act_y) >> 8;
  77:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         parent = lv_obj_get_parent(parent);
  78:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     }
  79:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
  80:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(scale_x == 0) {
  81:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         scale_x = 1;
  82:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     }
  83:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
