 266:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 267:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** lv_obj_t * lv_indev_find_scroll_obj(lv_indev_t * indev)
 268:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** {
 269:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     lv_obj_t * obj_candidate = NULL;
 270:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     lv_dir_t dir_candidate = LV_DIR_NONE;
 271:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int32_t scroll_limit = indev->scroll_limit;
 272:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 273:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     /*Go until find a scrollable object in the current direction
 274:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****      *More precisely:
 275:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****      * 1. Check the pressed object and all of its ancestors and try to find an object which is scro
 276:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****      * 2. Scrollable means it has some content out of its area
 277:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****      * 3. If an object can be scrolled into the current direction then use it ("real match"")
 278:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****      * 4. If can be scrolled on the current axis (hor/ver) save it as candidate (at least show an e
 279:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****      * 5. Use the last candidate. Always the "deepest" parent or the object from point 3*/
 280:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     lv_obj_t * obj_act = indev->pointer.act_obj;
 281:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 282:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     /*Decide if it's a horizontal or vertical scroll*/
 283:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     bool hor_en = false;
 284:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     bool ver_en = false;
 285:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     indev->pointer.scroll_sum.x += indev->pointer.vect.x;
 286:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     indev->pointer.scroll_sum.y += indev->pointer.vect.y;
 287:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 288:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     while(obj_act) {
 289:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*Get the transformed scroll_sum with this object*/
 290:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int16_t angle = 0;
 291:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int32_t scale_x = 256;
 292:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int32_t scale_y = 256;
 293:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         lv_point_t pivot = { 0, 0 };
 294:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         lv_obj_t * parent = obj_act;
 295:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         while(parent) {
 296:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             angle += lv_obj_get_style_transform_rotation(parent, 0);
 297:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             int32_t zoom_act_x = lv_obj_get_style_transform_scale_x_safe(parent, 0);
 298:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             int32_t zoom_act_y = lv_obj_get_style_transform_scale_y_safe(parent, 0);
 299:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             scale_x = (scale_x * zoom_act_x) >> 8;
 300:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             scale_y = (scale_y * zoom_act_y) >> 8;
 301:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             parent = lv_obj_get_parent(parent);
 302:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 303:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 304:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(scale_x == 0) {
 305:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             scale_x = 1;
 306:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 307:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 308:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(scale_y == 0) {
 309:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             scale_y = 1;
 310:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 311:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 312:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         lv_point_t obj_scroll_sum = indev->pointer.scroll_sum;
 313:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(angle != 0 || scale_x != LV_SCALE_NONE || scale_y != LV_SCALE_NONE) {
 314:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             angle = -angle;
 315:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             scale_x = (256 * 256) / scale_x;
 316:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             scale_y = (256 * 256) / scale_y;
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccZznpky.s 			page 7


 317:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             lv_point_transform(&obj_scroll_sum, angle, scale_x, scale_y, &pivot, false);
 318:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 319:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 320:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(LV_ABS(obj_scroll_sum.x) > LV_ABS(obj_scroll_sum.y)) {
 321:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             hor_en = true;
 322:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 323:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         else {
 324:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             ver_en = true;
 325:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 326:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 327:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLLABLE) == false) {
 328:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             /*If this object don't want to chain the scroll to the parent stop searching*/
 329:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLL_CHAIN_HOR) == false && hor_en) break;
 330:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLL_CHAIN_VER) == false && ver_en) break;
 331:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 332:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             obj_act = lv_obj_get_parent(obj_act);
 333:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             continue;
 334:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 335:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 336:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*Consider both up-down or left/right scrollable according to the current direction*/
 337:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         bool up_en = ver_en;
 338:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         bool down_en = ver_en;
 339:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         bool left_en = hor_en;
 340:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         bool right_en = hor_en;
 341:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 342:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*The object might have disabled some directions.*/
 343:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         lv_dir_t scroll_dir = lv_obj_get_scroll_dir(obj_act);
 344:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if((scroll_dir & LV_DIR_LEFT) == 0) left_en = false;
 345:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if((scroll_dir & LV_DIR_RIGHT) == 0) right_en = false;
 346:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if((scroll_dir & LV_DIR_TOP) == 0) up_en = false;
 347:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if((scroll_dir & LV_DIR_BOTTOM) == 0) down_en = false;
 348:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 349:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*Horizontal scroll*/
 350:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int32_t sl = 0;
 351:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int32_t sr = 0;
 352:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         lv_scroll_snap_t snap_x = lv_obj_get_scroll_snap_x(obj_act);
 353:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(snap_x == LV_SCROLL_SNAP_NONE) {
 354:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             sl = lv_obj_get_scroll_left(obj_act);
 355:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             sr = lv_obj_get_scroll_right(obj_act);
 356:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 357:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         else {
 358:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             bool has_start_snap;
 359:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             bool has_end_snap;
 360:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             has_more_snap_points(obj_act, LV_DIR_HOR, &has_start_snap, &has_end_snap);
 361:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 362:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             /*Assume scrolling is there are more snap point
 363:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****              *Assumed scroll in if there are NO more nap points*/
 364:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             sl = has_start_snap ? 1 : -1;
 365:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             sr = has_end_snap ? 1 : -1;
 366:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 367:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 368:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*Vertical scroll*/
 369:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int32_t st = 0;
 370:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         int32_t sb = 0;
 371:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         lv_scroll_snap_t snap_y = lv_obj_get_scroll_snap_y(obj_act);
 372:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(snap_y == LV_SCROLL_SNAP_NONE) {
 373:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             st = lv_obj_get_scroll_top(obj_act);
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccZznpky.s 			page 8


 374:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             sb = lv_obj_get_scroll_bottom(obj_act);
 375:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 376:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         else {
 377:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             bool has_start_snap;
 378:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             bool has_end_snap;
 379:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             has_more_snap_points(obj_act, LV_DIR_VER, &has_start_snap, &has_end_snap);
 380:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 381:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             /*Assume scrolling is there are more snap point
 382:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****              *Assumed scroll in if there are NO more nap points*/
 383:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             st = has_start_snap ? 1 : -1;
 384:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             sb = has_end_snap ? 1 : -1;
 385:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 386:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 387:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*If this object is scrollable into the current scroll direction then save it as a candidat
 388:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          *It's important only to be scrollable on the current axis (hor/ver) because if the scroll
 389:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          *is propagated to this object it can show at least elastic scroll effect.
 390:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****          *But if not hor/ver scrollable do not scroll it at all (so it's not a good candidate)*/
 391:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if((st > 0 || sb > 0)  &&
 392:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****            ((up_en    && obj_scroll_sum.y >=   scroll_limit) ||
 393:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             (down_en  && obj_scroll_sum.y <= - scroll_limit))) {
 394:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             obj_candidate = obj_act;
 395:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             dir_candidate = LV_DIR_VER;
 396:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 397:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 398:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if((sl > 0 || sr > 0)  &&
 399:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****            ((left_en   && obj_scroll_sum.x >=   scroll_limit) ||
 400:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             (right_en  && obj_scroll_sum.x <= - scroll_limit))) {
 401:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             obj_candidate = obj_act;
 402:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             dir_candidate = LV_DIR_HOR;
 403:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 404:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 405:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(st <= 0) up_en = false;
 406:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(sb <= 0) down_en = false;
 407:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(sl <= 0) left_en = false;
 408:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(sr <= 0) right_en = false;
 409:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 410:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*If the object really can be scrolled into the current direction then use it.*/
 411:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if((left_en  && obj_scroll_sum.x >=   scroll_limit) ||
 412:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****            (right_en && obj_scroll_sum.x <= - scroll_limit) ||
 413:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****            (up_en    && obj_scroll_sum.y >=   scroll_limit) ||
 414:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****            (down_en  && obj_scroll_sum.y <= - scroll_limit)) {
 415:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             indev->pointer.scroll_dir = hor_en ? LV_DIR_HOR : LV_DIR_VER;
 416:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             break;
 417:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         }
 418:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 419:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*If this object don't want to chain the scroll to the parent stop searching*/
 420:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLL_CHAIN_HOR) == false && hor_en) break;
 421:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag(obj_act, LV_OBJ_FLAG_SCROLL_CHAIN_VER) == false && ver_en) break;
 422:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 423:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         /*Try the parent*/
 424:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         obj_act = lv_obj_get_parent(obj_act);
 425:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     }
 426:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 427:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     /*Use the last candidate*/
 428:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(obj_candidate) {
 429:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         indev->pointer.scroll_dir = dir_candidate;
 430:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         indev->pointer.scroll_obj = obj_candidate;
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccZznpky.s 			page 9


 431:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         indev->pointer.scroll_sum.x = 0;
 432:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         indev->pointer.scroll_sum.y = 0;
 433:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     }
 434:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 435:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     return obj_candidate;
 436:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** }
