 236:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** int32_t lv_indev_scroll_throw_predict(lv_indev_t * indev, lv_dir_t dir)
 237:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** {
 238:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(indev == NULL) return 0;
 239:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int32_t v;
 240:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     switch(dir) {
 241:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         case LV_DIR_VER:
 242:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             v = indev->pointer.scroll_throw_vect_ori.y;
 243:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             break;
 244:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         case LV_DIR_HOR:
 245:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             v = indev->pointer.scroll_throw_vect_ori.x;
 246:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             break;
 247:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         default:
 248:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****             return 0;
 249:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     }
 250:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 251:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int32_t scroll_throw = indev->scroll_throw;
 252:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int32_t sum = 0;
 253:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     while(v) {
 254:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         sum += v;
 255:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         v = v * (100 - scroll_throw) / 100;
 256:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     }
 257:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 258:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     return sum;
 259:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** }
