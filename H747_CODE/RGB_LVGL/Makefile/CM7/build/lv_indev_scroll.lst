 494:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     /*`find_snap_point_x/y()` return LV_COORD_MAX is not snap point was found,
 495:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****      *but x1/y1 should be small. */
 496:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(indev->pointer.scroll_area.x1 == LV_COORD_MAX) indev->pointer.scroll_area.x1 = LV_COORD_MIN;
 497:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(indev->pointer.scroll_area.y1 == LV_COORD_MAX) indev->pointer.scroll_area.y1 = LV_COORD_MIN;
 498:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 499:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     /*Allow scrolling on the edges. It will be reverted to the edge due to snapping anyway*/
 500:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(indev->pointer.scroll_area.x1 == 0) indev->pointer.scroll_area.x1 = LV_COORD_MIN;
 501:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(indev->pointer.scroll_area.x2 == 0) indev->pointer.scroll_area.x2 = LV_COORD_MAX;
 502:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(indev->pointer.scroll_area.y1 == 0) indev->pointer.scroll_area.y1 = LV_COORD_MIN;
 503:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(indev->pointer.scroll_area.y2 == 0) indev->pointer.scroll_area.y2 = LV_COORD_MAX;
 504:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** }
 505:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 506:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** /**
 507:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  * Search for snap point in the min..max range.
 508:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  * @param obj the object on which snap point should be found
 509:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  * @param min ignore snap points smaller than this. (Absolute coordinate)
 510:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  * @param max ignore snap points greater than this. (Absolute coordinate)
 511:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  * @param ofs offset to snap points. Useful the get a snap point in an imagined case
 512:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  *            what if children are already moved by this value
 513:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  * @return the absolute x coordinate of the nearest snap point
 514:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  *         or `LV_COORD_MAX` if there is no snap point in the min..max range
 515:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****  */
 516:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** static int32_t find_snap_point_x(const lv_obj_t * obj, int32_t min, int32_t max, int32_t ofs)
 517:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** {
 518:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     lv_scroll_snap_t align = lv_obj_get_scroll_snap_x(obj);
 519:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     if(align == LV_SCROLL_SNAP_NONE) return LV_COORD_MAX;
 520:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 521:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int32_t dist = LV_COORD_MAX;
 522:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 523:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int32_t pad_left = lv_obj_get_style_pad_left(obj, LV_PART_MAIN);
 524:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     int32_t pad_right = lv_obj_get_style_pad_right(obj, LV_PART_MAIN);
 525:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c **** 
 526:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     uint32_t i;
 527:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     uint32_t child_cnt = lv_obj_get_child_count(obj);
 528:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****     for(i = 0; i < child_cnt; i++) {
 529:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         lv_obj_t * child = obj->spec_attr->children[i];
 530:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag_any(child, LV_OBJ_FLAG_HIDDEN | LV_OBJ_FLAG_FLOATING)) continue;
 531:../../Middlewares/LVGL/GUI/lvgl/src/indev/lv_indev_scroll.c ****         if(lv_obj_has_flag(child, LV_OBJ_FLAG_SNAPPABLE)) {
