 148:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 149:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c **** void lv_draw_sw_rgb565_swap(void * buf, uint32_t buf_size_px)
 150:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c **** {
 151:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     if(LV_DRAW_SW_RGB565_SWAP(buf, buf_size_px) == LV_RESULT_OK) return;
 152:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 153:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint16_t * buf16 = buf;
 154:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 155:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     /*2 pixels will be processed later, so handle 1 pixel alignment*/
 156:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     if((lv_uintptr_t)buf16 & 0x2) {
 157:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf16[0] = ((buf16[0] & 0xff00) >> 8) | ((buf16[0] & 0x00ff) << 8);
 158:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf16++;
 159:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****         buf_size_px--;
 160:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     }
 161:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 162:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint32_t * buf32 = (uint32_t *)buf16;
 163:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     uint32_t u32_cnt = buf_size_px / 2;
 164:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c **** 
 165:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_utils.c ****     while(u32_cnt >= 8) {
