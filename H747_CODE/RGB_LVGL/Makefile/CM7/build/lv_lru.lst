 101:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c **** void lv_lru_delete(lv_lru_t * cache)
 102:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c **** {
 103:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     LV_ASSERT_NULL(cache);
 104:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c **** 
 105:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     // free each of the cached items, and the hash table
 106:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     lv_lru_item_t * item = NULL, * next = NULL;
 107:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     uint32_t i = 0;
 108:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     if(cache->items) {
 109:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****         for(; i < cache->hash_table_size; i++) {
 110:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****             item = cache->items[i];
 111:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****             while(item) {
 112:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****                 next = (lv_lru_item_t *) item->next;
 113:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****                 cache->value_free(item->value);
 114:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****                 cache->key_free(item->key);
 115:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****                 cache->free_memory += item->value_length;
 116:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****                 lv_free(item);
 117:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****                 item = next;
 118:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****             }
 119:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****         }
 120:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****         lv_free(cache->items);
 121:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     }
 122:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c **** 
 123:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     if(cache->free_items) {
 124:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****         item = cache->free_items;
 125:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****         while(item) {
 126:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****             next = (lv_lru_item_t *) item->next;
 127:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****             lv_free(item);
 128:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****             item = next;
 129:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****         }
 130:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     }
 131:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c **** 
 132:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     // free the cache
 133:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c ****     lv_free(cache);
 134:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_lru.c **** }
