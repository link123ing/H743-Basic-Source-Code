 323:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** static void lv_buttonmatrix_event(const lv_obj_class_t * class_p, lv_event_t * e)
 324:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** {
 325:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     LV_UNUSED(class_p);
 326:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 327:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_result_t res;
 328:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 329:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     /*Call the ancestor's event handler*/
 330:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     res = lv_obj_event_base(MY_CLASS, e);
 331:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     if(res != LV_RESULT_OK) return;
 332:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 333:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_event_code_t code = lv_event_get_code(e);
 334:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_obj_t * obj = lv_event_get_current_target(e);
 335:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_buttonmatrix_t * btnm = (lv_buttonmatrix_t *)obj;
 336:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     lv_point_t p;
 337:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
 338:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     if(code == LV_EVENT_REFR_EXT_DRAW_SIZE) {
 339:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****         if(has_popovers_in_top_row(obj)) {
 340:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****             /*reserve one row worth of extra space to account for popovers in the top row*/
 341:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****             int32_t s = btnm->row_cnt > 0 ? lv_obj_get_content_height(obj) / btnm->row_cnt : 0;
 342:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****             lv_event_set_ext_draw_size(e, s);
 343:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****         }
 344:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     }
 345:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     if(code == LV_EVENT_STYLE_CHANGED) {
 346:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****         update_map(obj);
 347:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     }
 348:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     else if(code == LV_EVENT_SIZE_CHANGED) {
 349:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****         update_map(obj);
 350:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     }
 351:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****     else if(code == LV_EVENT_PRESSED) {
 352:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****         lv_indev_t * indev = lv_event_get_indev(e);
 353:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c ****         invalidate_button_area(obj, btnm->btn_id_sel);
 354:../../Middlewares/LVGL/GUI/lvgl/src/widgets/buttonmatrix/lv_buttonmatrix.c **** 
