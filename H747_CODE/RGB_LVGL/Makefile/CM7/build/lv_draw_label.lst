 106:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** /**
 107:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****  * Test if char is break char or not (a text can broken here or not)
 108:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****  * @param letter a letter
 109:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****  * @return false: 'letter' is not break char
 110:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****  */
 111:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** static inline bool lv_text_is_a_word(uint32_t letter)
 112:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** {
 113:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     /*Cheap check on invalid letter*/
 114:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter == 0) return false;
 115:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** 
 116:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK Unified Ideographs*/
 117:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x4E00 && letter <= 0x9FFF) {
 118:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 119:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     }
 120:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** 
 121:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     /*Fullwidth ASCII variants*/
 122:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0xFF01 && letter <= 0xFF5E) {
 123:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 124:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     }
 125:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** 
 126:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK symbols and punctuation*/
 127:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x3000 && letter <= 0x303F) {
 128:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 129:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     }
 130:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** 
 131:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK Radicals Supplement*/
 132:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x2E80 && letter <= 0x2EFF) {
 133:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 134:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     }
 135:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** 
 136:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     /*CJK Strokes*/
 137:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x31C0 && letter <= 0x31EF) {
 138:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 139:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     }
 140:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h **** 
 141:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     /*Hiragana and Katakana*/
 142:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     if(letter >= 0x3040 && letter <= 0x30FF) {
 143:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****         return true;
 144:../../Middlewares/LVGL/GUI/lvgl/src/draw/../misc/lv_text_private.h ****     }
