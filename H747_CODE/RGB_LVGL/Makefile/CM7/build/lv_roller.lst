 206:../../Middlewares/LVGL/GUI/lvgl/src/widgets/roller/lv_roller.c ****             uint32_t act_opt = roller->sel_opt_id - current_page * real_option_cnt;
 207:../../Middlewares/LVGL/GUI/lvgl/src/widgets/roller/lv_roller.c ****             int32_t sel_opt_signed = sel_opt;
 208:../../Middlewares/LVGL/GUI/lvgl/src/widgets/roller/lv_roller.c ****             /*Huge jump? Probably from last to first or first to last option.*/
 209:../../Middlewares/LVGL/GUI/lvgl/src/widgets/roller/lv_roller.c ****             if((uint32_t)LV_ABS((int16_t)(act_opt - sel_opt)) > real_option_cnt / 2) {
