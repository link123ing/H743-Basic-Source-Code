 159:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 160:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_XRGB8888) {
 161:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         data[2] = color.red;
 162:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         data[1] = color.green;
 163:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         data[0] = color.blue;
 164:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         data[3] = 0xFF;
 165:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 166:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_ARGB8888) {
 167:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         lv_color32_t * buf = (lv_color32_t *)data;
 168:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         buf->red = color.red;
