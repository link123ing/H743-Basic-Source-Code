 112:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_draw_buf_t * draw_buf = canvas->draw_buf;
 113:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c **** 
 114:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     lv_color_format_t cf = draw_buf->header.cf;
 115:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     uint8_t * data = lv_draw_buf_goto_xy(draw_buf, x, y);
 116:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c **** 
 117:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     if(LV_COLOR_FORMAT_IS_INDEXED(cf)) {
 118:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         uint8_t shift;
 119:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         uint8_t c_int = color.blue;
 120:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         switch(cf) {
 121:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****             case LV_COLOR_FORMAT_I1:
 122:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 shift = 7 - (x & 0x7);
 123:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 break;
 124:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****             case LV_COLOR_FORMAT_I2:
 125:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 shift = 6 - 2 * (x & 0x3);
 126:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 break;
 127:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****             case LV_COLOR_FORMAT_I4:
 128:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 shift = 4 - 4 * (x & 0x1);
 129:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 break;
 130:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****             case LV_COLOR_FORMAT_I8:
 131:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 /*Indexed8 format is a easy case, process and return.*/
 132:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 shift = 0;
 133:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 *data = c_int;
 134:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****             default:
 135:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****                 return;
 136:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         }
 137:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c **** 
 138:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         uint8_t bpp = lv_color_format_get_bpp(cf);
 139:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         uint8_t mask = (1 << bpp) - 1;
 140:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         c_int &= mask;
 141:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         *data = (*data & ~(mask << shift)) | (c_int << shift);
 142:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     }
 143:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     else if(cf == LV_COLOR_FORMAT_L8) {
 144:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         *data = lv_color_luminance(color);
 145:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****     }
