 156:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         data[2] = color.red;
 157:../../Middlewares/LVGL/GUI/lvgl/src/widgets/canvas/lv_canvas.c ****         data[1] = color.green;
