 233:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c ****        || (index == old_index)) {
 234:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c **** 
 235:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c ****         return;
 236:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c ****     }
 237:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c **** 
 238:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c ****     int32_t i = old_index;
 239:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c ****     if(index < old_index) {
 240:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c ****         while(i > index)  {
 241:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c ****             parent->spec_attr->children[i] = parent->spec_attr->children[i - 1];
