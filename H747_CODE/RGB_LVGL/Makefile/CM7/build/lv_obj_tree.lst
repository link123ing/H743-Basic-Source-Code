 529:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c **** lv_obj_t * lv_obj_get_child_by_name(const lv_obj_t * parent, const char * path)
 530:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c **** {
 531:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_tree.c ****     LV_ASSERT_OBJ(parent, MY_CLASS);
