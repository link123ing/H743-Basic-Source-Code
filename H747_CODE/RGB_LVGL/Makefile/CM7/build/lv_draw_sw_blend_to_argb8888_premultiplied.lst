 748:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****             /* Compute final alpha value */
 749:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****             cache->res_alpha_saved = 255 - LV_OPA_MIX2(255 - fg.alpha, 255 - bg.alpha);
 750:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****             LV_ASSERT(cache->res_alpha_saved != 0);
