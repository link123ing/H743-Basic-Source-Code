 766:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****             cache->res_saved.alpha = cache->res_alpha_saved;
 767:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/blend/lv_draw_sw_blend_to_argb8888_premultiplied.c ****         }
