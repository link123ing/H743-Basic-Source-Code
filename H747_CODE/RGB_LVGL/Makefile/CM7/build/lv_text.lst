 311:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 312:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 313:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     return i;
 314:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** #else
 315:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(flag & LV_TEXT_FLAG_BREAK_ALL) return break_index;
 316:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(word_w_ptr != NULL) *word_w_ptr = 0; /*Return no word*/
 317:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     (void) break_letter_count;
 318:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     return 0;
 319:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** #endif
 320:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** }
