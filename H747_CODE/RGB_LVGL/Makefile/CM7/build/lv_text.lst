 322:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** uint32_t lv_text_get_next_line(const char * txt, uint32_t len,
 323:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                                const lv_font_t * font, int32_t letter_space,
 324:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                                int32_t max_width, int32_t * used_width, lv_text_flag_t flag)
 325:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** {
 326:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(used_width) *used_width = 0;
 327:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 328:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(txt == NULL) return 0;
 329:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(txt[0] == '\0') return 0;
 330:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(font == NULL) return 0;
 331:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 332:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     int32_t line_w = 0;
 333:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 334:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*If max_width doesn't matter simply find the new line character
 335:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****      *without thinking about word wrapping*/
 336:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if((flag & LV_TEXT_FLAG_EXPAND) || (flag & LV_TEXT_FLAG_FIT)) {
 337:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         uint32_t i;
 338:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         for(i = 0; i < len && txt[i] != '\n' && txt[i] != '\r' && txt[i] != '\0'; i++) {
 339:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             /*Just find the new line chars or string ends by incrementing `i`*/
 340:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 341:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(i < len && txt[i] != '\0') i++;    /*To go beyond `\n`*/
 342:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(used_width) *used_width = -1;
 343:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         return i;
 344:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 345:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 346:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(flag & LV_TEXT_FLAG_EXPAND) max_width = LV_COORD_MAX;
 347:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     lv_text_cmd_state_t cmd_state = LV_TEXT_CMD_STATE_WAIT;
 348:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 349:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     uint32_t i = 0;                                        /*Iterating index into txt*/
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccMimN1K.s 			page 13


 350:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 351:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     while(i < len && txt[i] != '\0' && max_width > 0) {
 352:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         lv_text_flag_t word_flag = flag;
 353:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(i == 0) word_flag |= LV_TEXT_FLAG_BREAK_ALL;
 354:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 355:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         uint32_t word_w = 0;
 356:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         uint32_t advance = lv_text_get_next_word(&txt[i], font, letter_space, max_width, word_flag,
 357:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         max_width -= word_w;
 358:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         line_w += word_w;
 359:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 360:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(advance == 0) {
 361:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             break;
 362:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 363:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 364:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         i += advance;
 365:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 366:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(txt[0] == '\n' || txt[0] == '\r') break;
 367:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 368:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(txt[i] == '\n' || txt[i] == '\r') {
 369:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             i++;  /*Include the following newline in the current line*/
 370:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             break;
 371:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 372:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 373:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
