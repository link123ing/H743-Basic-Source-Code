 293:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*Word is "long," but insufficient amounts can fit in provided space*/
 294:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(break_letter_count < LV_TXT_LINE_BREAK_LONG_PRE_MIN_LEN) {
