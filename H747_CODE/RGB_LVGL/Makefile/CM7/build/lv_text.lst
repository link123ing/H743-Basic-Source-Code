 299:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 300:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*Word is a "long", but letters may need to be better distributed*/
 301:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     {
 302:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         i = break_index;
 303:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         int32_t n_move = LV_TXT_LINE_BREAK_LONG_POST_MIN_LEN - (word_len - break_letter_count);
 304:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         /*Move pointer "i" backwards*/
 305:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         for(; n_move > 0; n_move--) {
