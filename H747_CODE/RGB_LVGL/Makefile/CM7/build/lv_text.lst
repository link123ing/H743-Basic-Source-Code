 604:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** /**
 605:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * Convert a wide character, e.g. 'Á' little endian to be UTF-8 compatible
 606:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @param c a wide character or a  Little endian number
 607:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @return `c` in big endian
 608:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  */
 609:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** static uint32_t lv_text_utf8_conv_wc(uint32_t c)
 610:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** {
 611:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** #if LV_BIG_ENDIAN_SYSTEM == 0
 612:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*Swap the bytes (UTF-8 is big endian, but the MCUs are little endian)*/
 613:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if((c & 0x80) != 0) {
 614:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         uint32_t swapped;
 615:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         uint8_t c8[4];
 616:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         lv_memcpy(c8, &c, 4);
 617:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         swapped = (c8[0] << 24) + (c8[1] << 16) + (c8[2] << 8) + (c8[3]);
 618:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         uint8_t i;
 619:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         for(i = 0; i < 4; i++) {
 620:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             if((swapped & 0xFF) == 0)
 621:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                 swapped = (swapped >> 8); /*Ignore leading zeros (they were in the end originally)*
 622:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 623:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         c = swapped;
 624:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 625:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** #endif
 626:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     return c;
 627:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** }
 628:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 629:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** /**
 630:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * Decode an UTF-8 character from a string.
