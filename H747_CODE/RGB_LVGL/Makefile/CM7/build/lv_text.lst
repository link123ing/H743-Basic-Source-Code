 140:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** bool lv_text_is_cmd(lv_text_cmd_state_t * state, uint32_t c)
 141:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** {
 142:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     bool ret = false;
 143:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 144:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(c == (uint32_t)LV_TXT_COLOR_CMD[0]) {
 145:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(*state == LV_TEXT_CMD_STATE_WAIT) { /*Start char*/
 146:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             *state = LV_TEXT_CMD_STATE_PAR;
 147:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             ret = true;
 148:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 149:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         /*Other start char in parameter is escaped cmd. char*/
 150:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         else if(*state == LV_TEXT_CMD_STATE_WAIT) {
 151:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             *state = LV_TEXT_CMD_STATE_WAIT;
 152:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 153:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         /*Command end*/
 154:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         else if(*state == LV_TEXT_CMD_STATE_IN) {
 155:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             *state = LV_TEXT_CMD_STATE_WAIT;
 156:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             ret = true;
 157:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 158:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 159:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 160:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*Skip the color parameter and wait the space after it*/
 161:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(*state == LV_TEXT_CMD_STATE_PAR) {
 162:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(c == ' ') {
 163:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             *state = LV_TEXT_CMD_STATE_IN; /*After the parameter the text is in the command*/
 164:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 165:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         ret = true;
 166:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 167:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
