 171:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** /**
 172:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * Get the next word of text. A word is delimited by break characters.
 173:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *
 174:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * If the word cannot fit in the max_width space, obey LV_TXT_LINE_BREAK_LONG_* rules.
 175:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *
 176:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * If the next word cannot fit anything, return 0.
 177:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *
 178:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * If the first character is a break character, returns the next index.
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccMimN1K.s 			page 10


 179:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *
 180:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * Example calls from lv_text_get_next_line() assuming sufficient max_width and
 181:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * txt = "Test text\n"
 182:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *        0123456789
 183:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *
 184:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * Calls would be as follows:
 185:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *     1. Return i=4, pointing at breakchar ' ', for the string "Test"
 186:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *     2. Return i=5, since i=4 was a breakchar.
 187:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *     3. Return i=9, pointing at breakchar '\n'
 188:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *     4. Parenting lv_text_get_next_line() would detect subsequent '\0'
 189:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *
 190:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * TODO: Returned word_w_ptr may overestimate the returned word's width when
 191:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * max_width is reached. In current usage, this has no impact.
 192:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  *
 193:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @param txt a '\0' terminated string
 194:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @param font pointer to a font
 195:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @param letter_space letter space
 196:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @param max_width max width of the text (break the lines to fit this size). Set COORD_MAX to avoi
 197:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @param flags settings for the text from 'txt_flag_type' enum
 198:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @param[out] word_w_ptr width (in pixels) of the parsed word. May be NULL.
 199:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @param cmd_state Pointer to a lv_text_cmd_state_t variable which stored the current state of com
 200:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  * @return the index of the first char of the next word (in byte index not letter index. With UTF-8
 201:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****  */
 202:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** static uint32_t lv_text_get_next_word(const char * txt, const lv_font_t * font,
 203:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                                       int32_t letter_space, int32_t max_width,
 204:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                                       lv_text_flag_t flag, uint32_t * word_w_ptr,
 205:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                                       lv_text_cmd_state_t * cmd_state)
 206:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** {
 207:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(txt == NULL || txt[0] == '\0') return 0;
 208:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(font == NULL) return 0;
 209:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 210:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(flag & LV_TEXT_FLAG_EXPAND) max_width = LV_COORD_MAX;
 211:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 212:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     uint32_t i = 0, i_next = 0, i_next_next = 0;  /*Iterating index into txt*/
 213:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     uint32_t letter = 0;      /*Letter at i*/
 214:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     uint32_t letter_next = 0; /*Letter at i_next*/
 215:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     int32_t letter_w;
 216:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     int32_t cur_w = 0;  /*Pixel Width of traversed string*/
 217:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     uint32_t word_len = 0;   /*Number of characters in the traversed word*/
 218:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     uint32_t break_index = NO_BREAK_FOUND; /*only used for "long" words*/
 219:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     uint32_t break_letter_count = 0; /*Number of characters up to the long word break point*/
 220:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 221:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     letter = lv_text_encoded_next(txt, &i_next);
 222:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     i_next_next = i_next;
 223:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 224:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*Obtain the full word, regardless if it fits or not in max_width*/
 225:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     while(txt[i] != '\0') {
 226:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         letter_next = lv_text_encoded_next(txt, &i_next_next);
 227:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         word_len++;
 228:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 229:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         /*Handle the recolor command*/
 230:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if((flag & LV_TEXT_FLAG_RECOLOR) != 0) {
 231:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             if(lv_text_is_cmd(cmd_state, letter)) {
 232:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                 i = i_next;
 233:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                 i_next = i_next_next;
 234:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                 letter = letter_next;
 235:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                 continue;   /*Skip the letter if it is part of a command*/
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccMimN1K.s 			page 11


 236:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             }
 237:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 238:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 239:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         letter_w = lv_font_get_glyph_width(font, letter, letter_next);
 240:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         cur_w += letter_w;
 241:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 242:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(letter_w > 0) {
 243:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             cur_w += letter_space;
 244:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 245:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 246:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         /*Test if this character fits within max_width*/
 247:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(break_index == NO_BREAK_FOUND && (cur_w - letter_space) > max_width) {
 248:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             break_index = i;
 249:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             break_letter_count = word_len - 1;
 250:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             if(flag & LV_TEXT_FLAG_BREAK_ALL) {
 251:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****                 break;
 252:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             }
 253:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             /*break_index is now pointing at the character that doesn't fit*/
 254:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 255:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 256:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         /*Check for new line chars and breakchars*/
 257:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(letter == '\n' || letter == '\r' || lv_text_is_break_char(letter)) {
 258:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             /*Update the output width on the first character if it fits.
 259:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****              *Must do this here in case first letter is a break character.*/
 260:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             if(i == 0 && break_index == NO_BREAK_FOUND && word_w_ptr != NULL) *word_w_ptr = cur_w;
 261:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             word_len--;
 262:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             break;
 263:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 264:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         else if(lv_text_is_a_word(letter_next) || lv_text_is_a_word(letter)) {
 265:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             /*Found a word for single letter, usually true for CJK*/
 266:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             *word_w_ptr = cur_w;
 267:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             i = i_next;
 268:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****             break;
 269:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         }
 270:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 271:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         /*Update the output width*/
 272:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(word_w_ptr != NULL && break_index == NO_BREAK_FOUND) *word_w_ptr = cur_w;
 273:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 274:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         i = i_next;
 275:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         i_next = i_next_next;
 276:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         letter = letter_next;
 277:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 278:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 279:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*Entire Word fits in the provided space*/
 280:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(break_index == NO_BREAK_FOUND) {
 281:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(word_len == 0 || (letter == '\r' && letter_next == '\n')) i = i_next;
 282:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         return i;
 283:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 284:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 285:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** #if LV_TXT_LINE_BREAK_LONG_LEN > 0
 286:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*Word doesn't fit in provided space, but isn't "long"*/
 287:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(word_len < LV_TXT_LINE_BREAK_LONG_LEN) {
 288:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(flag & LV_TEXT_FLAG_BREAK_ALL) return break_index;
 289:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         if(word_w_ptr != NULL) *word_w_ptr = 0; /*Return no word*/
 290:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         return 0;
 291:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 292:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
