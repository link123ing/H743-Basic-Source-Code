 481:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** void lv_text_cut(char * txt, uint32_t pos, uint32_t len)
 482:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** {
 483:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     if(txt == NULL) return;
 484:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 485:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     size_t old_len = lv_strlen(txt);
 486:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 487:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     pos = lv_text_encoded_get_byte_id(txt, pos); /*Convert to byte index instead of letter index*/
 488:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     len = lv_text_encoded_get_byte_id(&txt[pos], len);
 489:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** 
 490:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     /*Copy the second part into the end to make place to text to insert*/
 491:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     uint32_t i;
 492:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     for(i = pos; i <= old_len - len; i++) {
 493:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****         txt[i] = txt[i + len];
 494:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c ****     }
 495:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_text.c **** }
