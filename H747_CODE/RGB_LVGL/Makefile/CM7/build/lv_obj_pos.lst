 711:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****         x += lv_obj_get_style_space_left(parent, LV_PART_MAIN);
 712:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****         y += lv_obj_get_style_space_top(parent, LV_PART_MAIN);
 713:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     }
