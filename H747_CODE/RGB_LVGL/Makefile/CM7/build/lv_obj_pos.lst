 716:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     lv_point_t diff;
 717:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     diff.x = x - obj->coords.x1;
 718:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     diff.y = y - obj->coords.y1;
 719:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c **** 
 720:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     /*Do nothing if the position is not changed*/
 721:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     /*It is very important else recursive positioning can
 722:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****      *occur without position change*/
