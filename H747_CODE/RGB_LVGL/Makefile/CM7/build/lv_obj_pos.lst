 726:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     lv_obj_invalidate(obj);
 727:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c **** 
 728:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     /*Save the original coordinates*/
