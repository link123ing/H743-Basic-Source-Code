 696:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c **** void lv_obj_move_to(lv_obj_t * obj, int32_t x, int32_t y)
 697:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c **** {
 698:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     /*Convert x and y to absolute coordinates*/
 699:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     lv_obj_t * parent = obj->parent;
 700:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c **** 
 701:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****     if(parent) {
 702:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****         if(lv_obj_has_flag(obj, LV_OBJ_FLAG_FLOATING)) {
 703:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****             x += parent->coords.x1;
 704:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****             y += parent->coords.y1;
 705:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****         }
 706:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****         else {
 707:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****             x += parent->coords.x1 - lv_obj_get_scroll_x(parent);
 708:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****             y += parent->coords.y1 - lv_obj_get_scroll_y(parent);
 709:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_obj_pos.c ****         }
