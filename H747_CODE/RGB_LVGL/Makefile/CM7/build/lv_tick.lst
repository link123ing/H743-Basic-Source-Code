  53:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****     /*If `lv_tick_inc` is called from an interrupt while `sys_time` is read
  54:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****      *the result might be corrupted.
  55:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****      *This loop detects if `lv_tick_inc` was called while reading `sys_time`.
  56:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****      *If `tick_irq_flag` was cleared in `lv_tick_inc` try to read again
  57:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****      *until `tick_irq_flag` remains `1`.*/
  58:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****     uint32_t result;
  59:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****     do {
  60:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****         state_p->sys_irq_flag = 1;
  61:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****         result        = state_p->sys_time;
  62:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****     } while(!state_p->sys_irq_flag); /*Continue until see a non interrupted cycle*/
  63:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c **** 
  64:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c ****     return result;
  65:../../Middlewares/LVGL/GUI/lvgl/src/tick/lv_tick.c **** }
