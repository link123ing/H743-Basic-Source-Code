 677:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             /*Swap the time and reverse_duration*/
 678:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             tmp = a->duration;
 679:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             a->duration = a->reverse_duration;
