 640:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(a->reverse_play_in_progress == 0 && a->repeat_cnt > 0 && a->repeat_cnt != LV_ANIM_REPEAT_INF
 641:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         a->repeat_cnt--;
 642:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 643:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 644:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Delete animation if
 645:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****      * - no repeat left and no reverse play scheduled (simple one shot animation); or
 646:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****      * - no repeat, reverse play enabled (reverse_duration != 0) and reverse play is completed. */
 647:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(a->repeat_cnt == 0 && (a->reverse_duration == 0 || a->reverse_play_in_progress == 1)) {
 648:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 649:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Delete the animation from the list.
 650:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****          * This way the `completed_cb` will see the animations like it's animation is already delet
 651:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         lv_ll_remove(anim_ll_p, a);
 652:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Flag that the list has changed*/
 653:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         anim_mark_list_change();
 654:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 655:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Call the callback function at the end*/
 656:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if(a->completed_cb != NULL) a->completed_cb(a);
 657:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if(a->deleted_cb != NULL) a->deleted_cb(a);
 658:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         lv_free(a);
ARM GAS  C:\Users\28576\AppData\Local\Temp\cck4TgMw.s 			page 13


 659:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 660:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*If the animation is not deleted then restart it*/
 661:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     else {
 662:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Restart the animation. If the time is over a little compensate it.*/
 663:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         int32_t over_time = 0;
 664:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if(a->act_time > a->duration) over_time = a->act_time - a->duration;
 665:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         a->act_time = over_time - (int32_t)(a->repeat_delay);
 666:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Swap start and end values in reverse-play mode*/
 667:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if(a->reverse_duration != 0) {
 668:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             /*If now now playing in reverse, use the 'reverse_delay'.*/
 669:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             if(a->reverse_play_in_progress == 0) a->act_time = -(int32_t)(a->reverse_delay);
