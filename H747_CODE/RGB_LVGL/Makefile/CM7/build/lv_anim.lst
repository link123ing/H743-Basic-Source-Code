  94:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** lv_anim_t * lv_anim_start(const lv_anim_t * a)
  95:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
  96:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     LV_TRACE_ANIM("begin");
  97:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
  98:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Do not let two animations for the same 'var' with the same 'exec_cb'*/
  99:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(a->early_apply && (a->exec_cb || a->custom_exec_cb)) {
 100:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         remove_concurrent_anims(a);
 101:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 102:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 103:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Add the new animation to the animation linked list*/
 104:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     lv_anim_t * new_anim = lv_ll_ins_head(anim_ll_p);
 105:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     LV_ASSERT_MALLOC(new_anim);
 106:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(new_anim == NULL) return NULL;
 107:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 108:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Initialize the animation descriptor*/
 109:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     lv_memcpy(new_anim, a, sizeof(lv_anim_t));
 110:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(a->var == a) new_anim->var = new_anim;
 111:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_anim->run_round = state.anim_run_round;
 112:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_anim->last_timer_run = lv_tick_get();
 113:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_anim->is_paused = false;
 114:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 115:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Set the start value*/
 116:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(new_anim->early_apply) {
 117:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if(new_anim->get_value_cb) {
 118:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             int32_t v_ofs = new_anim->get_value_cb(new_anim);
 119:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             new_anim->start_value += v_ofs;
 120:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             new_anim->end_value += v_ofs;
 121:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 122:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         }
 123:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 124:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         resolve_time(new_anim);
 125:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 126:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         new_anim->current_value = new_anim->path_cb(new_anim);
 127:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if(new_anim->exec_cb) {
 128:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             new_anim->exec_cb(new_anim->var, new_anim->current_value);
 129:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         }
 130:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if(new_anim->custom_exec_cb) {
 131:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             new_anim->custom_exec_cb(new_anim, new_anim->current_value);
 132:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         }
 133:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 134:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 135:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Creating an animation changed the linked list.
 136:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****      *It's important if it happens in a ready callback. (see `anim_timer`)*/
 137:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     anim_mark_list_change();
 138:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 139:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     LV_TRACE_ANIM("finished");
 140:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return new_anim;
 141:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
