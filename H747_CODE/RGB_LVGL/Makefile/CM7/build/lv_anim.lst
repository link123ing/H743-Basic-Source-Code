 212:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** uint32_t lv_anim_speed_clamped(uint32_t speed, uint32_t min_time, uint32_t max_time)
 213:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 214:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 215:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(speed > 10000) {
 216:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         LV_LOG_WARN("speed is truncated to 10000 (was %"LV_PRIu32")", speed);
 217:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         speed = 10230;
 218:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 219:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(min_time > 10000) {
 220:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         LV_LOG_WARN("min_time is truncated to 10000 (was %"LV_PRIu32")", min_time);
 221:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         min_time = 10230;
 222:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 223:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(max_time > 10000) {
 224:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         LV_LOG_WARN("max_time is truncated to 10000 (was %"LV_PRIu32")", max_time);
 225:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         max_time = 10230;
 226:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 227:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 228:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Lower the resolution to fit the 0.1023 range*/
 229:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     speed = (speed + 5) / 10;
 230:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     min_time = (min_time + 5) / 10;
 231:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     max_time = (max_time + 5) / 10;
 232:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 233:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return LV_ANIM_SPEED_MASK + (max_time << 20) + (min_time << 10) + speed;
 234:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 235:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
 236:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 237:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** uint32_t lv_anim_speed(uint32_t speed)
 238:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 239:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return lv_anim_speed_clamped(speed, 0, 10000);
 240:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
