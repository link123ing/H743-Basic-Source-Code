 724:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** /**
 725:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****  * Remove animations which are animating the same var with the same exec_cb
 726:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****  * and they are already running or they have early_apply
 727:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****  * @param a_current     the current animation, use its var and exec_cb as reference to know what to
 728:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****  * @return              true: at least one animation was delete
 729:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****  */
 730:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** static bool remove_concurrent_anims(const lv_anim_t * a_current)
 731:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
ARM GAS  C:\Users\28576\AppData\Local\Temp\cck4TgMw.s 			page 15


 732:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(a_current->exec_cb == NULL && a_current->custom_exec_cb == NULL) return false;
 733:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 734:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     lv_anim_t * a;
 735:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     bool del_any = false;
 736:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     a = lv_ll_get_head(anim_ll_p);
 737:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     while(a != NULL) {
 738:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         bool del = false;
 739:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*We can't test for custom_exec_cb equality because in the MicroPython binding
 740:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****          *a wrapper callback is used here an the real callback data is stored in the `user_data`.
 741:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****          *Therefore equality check would remove all animations.*/
 742:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if(a != a_current &&
 743:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****            (a->act_time >= 0 || a->early_apply) &&
 744:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****            (a->var == a_current->var) &&
 745:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****            ((a->exec_cb && a->exec_cb == a_current->exec_cb)
 746:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             /*|| (a->custom_exec_cb && a->custom_exec_cb == a_current->custom_exec_cb)*/)) {
 747:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             lv_ll_remove(anim_ll_p, a);
 748:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             if(a->deleted_cb != NULL) a->deleted_cb(a);
 749:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             lv_free(a);
 750:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             /*Read by `anim_timer`. It need to know if a delete occurred in the linked list*/
 751:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             anim_mark_list_change();
 752:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 753:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             del_any = true;
 754:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             del = true;
 755:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         }
 756:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 757:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Always start from the head on delete, because we don't know
 758:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****          *how `anim_ll_p` was changes in `a->deleted_cb` */
 759:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         a = del ? lv_ll_get_head(anim_ll_p) : lv_ll_get_next(anim_ll_p, a);
 760:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 761:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 762:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return del_any;
 763:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
