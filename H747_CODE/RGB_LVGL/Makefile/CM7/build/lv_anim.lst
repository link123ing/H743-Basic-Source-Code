 143:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** uint32_t lv_anim_get_playtime(const lv_anim_t * a)
 144:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 145:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(a->repeat_cnt == LV_ANIM_REPEAT_INFINITE) {
ARM GAS  C:\Users\28576\AppData\Local\Temp\cck4TgMw.s 			page 4


 146:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         return LV_ANIM_PLAYTIME_INFINITE;
 147:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 148:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 149:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t repeat_cnt = a->repeat_cnt;
 150:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(repeat_cnt < 1) repeat_cnt = 1;
 151:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 152:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t playtime = a->repeat_delay + a->duration + a->reverse_delay + a->reverse_duration;
 153:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     playtime = playtime * repeat_cnt;
 154:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return playtime;
 155:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
