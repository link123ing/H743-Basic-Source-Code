 694:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** static int32_t lv_anim_path_cubic_bezier(const lv_anim_t * a, int32_t x1, int32_t y1, int32_t x2, i
 695:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 696:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Calculate the current step*/
 697:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t t = lv_map(a->act_time, 0, a->duration, 0, LV_BEZIER_VAL_MAX);
 698:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     int32_t step = lv_cubic_bezier(t, x1, y1, x2, y2);
 699:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 700:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     int32_t new_value;
 701:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_value = step * (a->end_value - a->start_value);
 702:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_value = new_value >> LV_BEZIER_VAL_SHIFT;
 703:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_value += a->start_value;
 704:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 705:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return new_value;
 706:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
