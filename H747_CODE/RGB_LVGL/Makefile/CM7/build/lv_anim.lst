 493:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** uint32_t lv_anim_resolve_speed(uint32_t speed_or_time, int32_t start, int32_t end)
 494:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 495:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*It was a simple time*/
 496:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if((speed_or_time & LV_ANIM_SPEED_MASK) == 0) return speed_or_time;
 497:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 498:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t d    = LV_ABS(start - end);
 499:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t speed = speed_or_time & 0x3FF;
 500:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t time = (d * 100) / speed; /*Speed is in 10 units per sec*/
 501:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t max_time = (speed_or_time >> 20) & 0x3FF;
 502:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t min_time = (speed_or_time >> 10) & 0x3FF;
 503:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 504:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return LV_CLAMP(min_time * 10, time, max_time * 10);
 505:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
