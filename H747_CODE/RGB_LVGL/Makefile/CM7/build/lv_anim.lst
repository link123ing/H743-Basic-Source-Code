 242:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** uint32_t lv_anim_speed_to_time(uint32_t speed, int32_t start, int32_t end)
 243:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 244:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t d = LV_ABS(start - end);
 245:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     uint32_t time = (d * 1000) / speed;
 246:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 247:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     time = time == 0 ? 1 : time;
 248:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 249:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return time;
 250:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
