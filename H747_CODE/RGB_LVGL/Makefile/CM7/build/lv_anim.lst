 260:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     int32_t step = lv_map(a->act_time, 0, a->duration, 0, LV_ANIM_RESOLUTION);
 261:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 262:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Get the new value which will be proportional to `step`
 263:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****      *and the `start` and `end` values*/
