 672:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             a->reverse_play_in_progress = a->reverse_play_in_progress == 0 ? 1 : 0;
 673:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             /*Swap the start and end values*/
 674:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             int32_t tmp    = a->start_value;
