 295:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** int32_t lv_anim_path_bounce(const lv_anim_t * a)
 296:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 297:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*Calculate the current step*/
 298:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     int32_t t = lv_map(a->act_time, 0, a->duration, 0, LV_BEZIER_VAL_MAX);
 299:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     int32_t diff = (a->end_value - a->start_value);
 300:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 301:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     /*3 bounces has 5 parts: 3 down and 2 up. One part is t / 5 long*/
 302:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 303:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(t < 408) {
 304:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Go down*/
 305:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t = (t * 2500) >> LV_BEZIER_VAL_SHIFT; /*[0..1024] range*/
 306:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t = LV_BEZIER_VAL_MAX - t;
 307:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 308:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     else if(t >= 408 && t < 614) {
 309:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*First bounce back*/
 310:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t -= 408;
 311:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t    = t * 5; /*to [0..1024] range*/
 312:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         diff = diff / 20;
 313:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 314:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     else if(t >= 614 && t < 819) {
 315:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Fall back*/
 316:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t -= 614;
ARM GAS  C:\Users\28576\AppData\Local\Temp\cck4TgMw.s 			page 7


 317:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t    = t * 5; /*to [0..1024] range*/
 318:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t    = LV_BEZIER_VAL_MAX - t;
 319:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         diff = diff / 20;
 320:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 321:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     else if(t >= 819 && t < 921) {
 322:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Second bounce back*/
 323:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t -= 819;
 324:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t    = t * 10; /*to [0..1024] range*/
 325:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         diff = diff / 40;
 326:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 327:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     else if(t >= 921 && t <= LV_BEZIER_VAL_MAX) {
 328:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Fall back*/
 329:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t -= 921;
 330:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t    = t * 10; /*to [0..1024] range*/
 331:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         t    = LV_BEZIER_VAL_MAX - t;
 332:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         diff = diff / 40;
 333:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 334:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 335:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(t > LV_BEZIER_VAL_MAX) t = LV_BEZIER_VAL_MAX;
 336:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(t < 0) t = 0;
 337:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     int32_t step = lv_bezier3(t, 0, 500, 800, LV_BEZIER_VAL_MAX);
 338:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 339:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     int32_t new_value;
 340:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_value = step * diff;
 341:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_value = new_value >> LV_BEZIER_VAL_SHIFT;
 342:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     new_value = a->end_value - new_value;
 343:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 344:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return new_value;
 345:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
 346:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 347:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** int32_t lv_anim_path_step(const lv_anim_t * a)
 348:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 349:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     if(a->act_time >= a->duration)
 350:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         return a->end_value;
 351:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     else
 352:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         return a->start_value;
 353:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
