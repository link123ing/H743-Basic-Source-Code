 157:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** bool lv_anim_delete(void * var, lv_anim_exec_xcb_t exec_cb)
 158:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** {
 159:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     lv_anim_t * a;
 160:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     bool del_any = false;
 161:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     a        = lv_ll_get_head(anim_ll_p);
 162:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     while(a != NULL) {
 163:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         bool del = false;
 164:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         if((a->var == var || var == NULL) && (a->exec_cb == exec_cb || exec_cb == NULL)) {
 165:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             remove_anim(a);
 166:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             anim_mark_list_change(); /*Read by `anim_timer`. It need to know if a delete occurred i
 167:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****                                        the linked list*/
 168:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             del_any = true;
 169:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****             del = true;
 170:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         }
 171:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 172:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         /*Always start from the head on delete, because we don't know
 173:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****          *how `anim_ll_p` was changes in `a->deleted_cb` */
 174:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****         a = del ? lv_ll_get_head(anim_ll_p) : lv_ll_get_next(anim_ll_p, a);
 175:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     }
 176:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 177:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c ****     return del_any;
 178:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** }
 179:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** 
 180:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_anim.c **** void lv_anim_delete_all(void)
