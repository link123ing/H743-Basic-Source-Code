 188:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c **** lv_image_src_t lv_image_src_get_type(const void * src)
 189:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c **** {
 190:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     if(src == NULL) return LV_IMAGE_SRC_UNKNOWN;
 191:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     const uint8_t * u8_p = src;
 192:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c **** 
 193:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     /*The first byte shows the type of the image source*/
 194:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     if(u8_p[0] >= 0x20 && u8_p[0] <= 0x7F) {
 195:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****         return LV_IMAGE_SRC_FILE; /*If it's an ASCII character then it's file name*/
 196:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     }
 197:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     else if(u8_p[0] >= 0x80) {
 198:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****         return LV_IMAGE_SRC_SYMBOL; /*Symbols begins after 0x7F*/
 199:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     }
 200:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     else {
 201:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****         return LV_IMAGE_SRC_VARIABLE; /*`lv_image_dsc_t` is draw to the first byte < 0x20*/
 202:../../Middlewares/LVGL/GUI/lvgl/src/draw/lv_draw_image.c ****     }
