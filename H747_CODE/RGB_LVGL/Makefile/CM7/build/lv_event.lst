  57:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** void lv_event_push(lv_event_t * e)
  58:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** {
  59:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     /*Build a simple linked list from the objects used in the events
  60:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****      *It's important to know if this object was deleted by a nested event
  61:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****      *called from this `event_cb`.*/
  62:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     e->prev = event_head;
  63:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     event_head = e;
  64:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
  65:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** }
  66:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
  67:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** void lv_event_pop(lv_event_t * e)
  68:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** {
  69:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     event_head = e->prev;
  70:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** }
  71:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
  72:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** lv_result_t lv_event_send(lv_event_list_t * list, lv_event_t * e, bool preprocess)
  73:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** {
  74:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     if(list == NULL) return LV_RESULT_OK;
  75:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     if(e->deleted) return LV_RESULT_INVALID;
  76:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
  77:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     /* When obj is deleted in its own event, it will cause the `list->array` header to be released,
  78:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****      * but the content still exists, which leads to memory leakage.
  79:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****      * Therefore, back up the header in advance,
  80:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****      * which can strive to release the memory and prevent used-after-free. */
  81:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     lv_array_t back_array_head = list->array;
  82:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
  83:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     /* Dealing with the problem of nested event deletion event */
  84:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     const bool is_traversing = list->is_traversing;
  85:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     list->is_traversing = true;
  86:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
  87:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     lv_result_t res = LV_RESULT_OK;
  88:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     const uint32_t size = event_array_size(list);
ARM GAS  C:\Users\28576\AppData\Local\Temp\ccwuB5AB.s 			page 3


  89:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     for(uint32_t i = 0; i < size && !e->deleted; i++) {
  90:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         lv_event_dsc_t * dsc = *event_array_at(list, i);
  91:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         if(dsc->cb == NULL) continue;
  92:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         if(event_is_marked_deleting(dsc)) continue;
  93:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         const bool is_preprocessed = (dsc->filter & LV_EVENT_PREPROCESS) != 0;
  94:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         if(is_preprocessed != preprocess) continue;
  95:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         lv_event_code_t filter = dsc->filter & ~LV_EVENT_PREPROCESS;
  96:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         if(filter == LV_EVENT_ALL || filter == e->code) {
  97:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****             e->user_data = dsc->user_data;
  98:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****             dsc->cb(e);
  99:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****             if(e->stop_processing) break;
 100:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
 101:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****             /*Stop if the object is deleted*/
 102:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****             if(e->deleted) {
 103:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****                 res = LV_RESULT_INVALID;
 104:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****                 break;
 105:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****             }
 106:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         }
 107:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     }
 108:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
 109:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     if(is_traversing) return res;
 110:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
 111:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     if(e->deleted) cleanup_event_list_core(&back_array_head);
 112:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     else {
 113:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         list->is_traversing = false;
 114:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****         cleanup_event_list(list);
 115:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     }
 116:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** 
 117:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c ****     return res;
 118:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_event.c **** }
