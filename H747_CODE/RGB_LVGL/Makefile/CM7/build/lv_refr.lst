1299:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** static uint32_t get_max_row(lv_display_t * disp, int32_t area_w, int32_t area_h)
1300:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** {
