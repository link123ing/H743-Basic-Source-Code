1303:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     uint32_t overhead = LV_COLOR_INDEXED_PALETTE_SIZE(cf) * sizeof(lv_color32_t);
1304:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1305:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(stride == 0) {
