1309:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1310:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     int32_t max_row = (uint32_t)(disp->buf_act->data_size - overhead) / stride;
1311:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1312:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(max_row > area_h) max_row = area_h;
1313:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1314:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*Round down the lines of draw_buf if rounding is added*/
