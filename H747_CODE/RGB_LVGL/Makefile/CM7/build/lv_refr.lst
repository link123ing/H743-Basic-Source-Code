 743:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         uint32_t i;
 744:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         for(i = 0; i < tile_cnt; i++) {
 745:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             lv_area_t tile_area;
 746:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             lv_area_set(&tile_area, area_p->x1, area_p->y1 + i * tile_h,
 747:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****                         area_p->x2, area_p->y1 + (i + 1) * tile_h - 1);
