 716:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         /* Assume that the the buffer size (can be screen sized or smaller in case of partial mode)
 717:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****          * and max tile size are the optimal scenario. From this calculate the ideal tile size
 718:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****          * and set the tile count and tile height accordingly.
 719:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****          */
 720:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         uint32_t max_tile_cnt = disp_refr->tile_cnt;
 721:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         uint32_t total_buf_size = layer->draw_buf->data_size;
 722:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         uint32_t ideal_tile_size = total_buf_size / max_tile_cnt;
 723:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         uint32_t area_buf_size = lv_area_get_size(area_p) * lv_color_format_get_size(layer->color_f
 724:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 725:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         tile_cnt = (area_buf_size + (ideal_tile_size - 1)) / ideal_tile_size; /*Round up*/
 726:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         tile_h = lv_area_get_height(area_p) / tile_cnt;
 727:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     }
 728:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 729:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(tile_cnt == 1) {
