 752:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 753:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             lv_layer_t * tile_layer = &tile_layers[i];
 754:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             lv_draw_layer_init(tile_layer, NULL, layer->color_format, &tile_area);
 755:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             tile_layer->buf_area = layer->buf_area; /*the buffer is still large*/
 756:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             tile_layer->draw_buf = layer->draw_buf;
