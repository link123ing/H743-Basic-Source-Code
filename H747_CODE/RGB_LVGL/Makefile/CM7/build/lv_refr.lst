1316:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     tmp.x1 = 0;
1317:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     tmp.x2 = 0;
1318:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     tmp.y1 = 0;
1319:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1320:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     int32_t h_tmp = max_row;
1321:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     do {
1322:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         tmp.y2 = h_tmp - 1;
1323:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         lv_display_send_event(disp_refr, LV_EVENT_INVALIDATE_AREA, &tmp);
1324:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1325:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         /*If this height fits into `max_row` then fine*/
1326:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         if(lv_area_get_height(&tmp) <= max_row) break;
1327:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1328:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         /*Decrement the height of the area until it fits into `max_row` after rounding*/
1329:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         h_tmp--;
1330:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     } while(h_tmp > 0);
1331:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1332:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(h_tmp <= 0) {
1333:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         LV_LOG_WARN("Can't set draw_buf height using the round function. (Wrong round_cb or too "
1334:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****                     "small draw_buf)");
1335:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         return 0;
1336:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     }
1337:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     else {
1338:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         max_row = tmp.y2 + 1;
1339:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     }
1340:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
1341:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     return max_row;
1342:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** }
