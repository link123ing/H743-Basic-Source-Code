 598:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*Notify the display driven rendering has started*/
 599:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     lv_display_send_event(disp_refr, LV_EVENT_RENDER_START, NULL);
