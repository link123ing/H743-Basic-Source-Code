 731:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     }
 732:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     else {
 733:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         /* Don't draw to the layers buffer of the display but create smaller dummy layers which are
 734:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****          * display's layer buffer. These will be the tiles. By using tiles it's more likely that th
 735:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****          * be independent areas for each draw unit. */
 736:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         lv_layer_t * tile_layers = lv_malloc(tile_cnt * sizeof(lv_layer_t));
