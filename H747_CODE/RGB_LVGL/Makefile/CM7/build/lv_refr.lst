 905:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** /**
 906:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  * Search the most top object which fully covers an area
 907:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  * @param area_p pointer to an area
 908:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  * @param obj the first object to start the searching (typically a screen)
 909:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  * @return
 910:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  */
 911:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** static lv_obj_t * lv_refr_get_top_obj(const lv_area_t * area_p, lv_obj_t * obj)
 912:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** {
 913:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     lv_obj_t * found_p = NULL;
 914:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 915:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(lv_area_is_in(area_p, &obj->coords, 0) == false) return NULL;
 916:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(lv_obj_has_flag(obj, LV_OBJ_FLAG_HIDDEN)) return NULL;
 917:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(lv_obj_get_layer_type(obj) != LV_LAYER_TYPE_NONE) return NULL;
 918:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(lv_obj_get_style_opa(obj, LV_PART_MAIN) < LV_OPA_MAX) return NULL;
 919:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 920:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*If this object is fully cover the draw area then check the children too*/
 921:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     lv_cover_check_info_t info;
 922:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     info.res = LV_COVER_RES_COVER;
 923:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     info.area = area_p;
 924:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     lv_obj_send_event(obj, LV_EVENT_COVER_CHECK, &info);
 925:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(info.res == LV_COVER_RES_MASKED) return NULL;
 926:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 927:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     int32_t i;
 928:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     int32_t child_cnt = lv_obj_get_child_count(obj);
 929:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     for(i = child_cnt - 1; i >= 0; i--) {
 930:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         lv_obj_t * child = obj->spec_attr->children[i];
 931:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         found_p = lv_refr_get_top_obj(area_p, child);
 932:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 933:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         /*If a children is ok then break*/
 934:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         if(found_p != NULL) {
 935:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             break;
 936:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         }
 937:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     }
 938:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 939:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*If no better children use this object*/
 940:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(found_p == NULL && info.res == LV_COVER_RES_COVER) {
 941:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         found_p = obj;
 942:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     }
 943:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
ARM GAS  C:\Users\28576\AppData\Local\Temp\cc1D0Uwr.s 			page 18


 944:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     return found_p;
 945:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** }
