 947:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** /**
 948:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  * Make the refreshing from an object. Draw all its children and the youngers too.
 949:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  * @param top_p pointer to an objects. Start the drawing from it.
 950:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  * @param mask_p pointer to an area, the objects will be drawn only here
 951:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****  */
 952:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** static void refr_obj_and_children(lv_layer_t * layer, lv_obj_t * top_obj)
 953:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** {
 954:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*Normally always will be a top_obj (at least the screen)
 955:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****      *but in special cases (e.g. if the screen has alpha) it won't.
 956:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****      *In this case use the screen directly*/
 957:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(top_obj == NULL) top_obj = lv_display_get_screen_active(disp_refr);
 958:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(top_obj == NULL) return;  /*Shouldn't happen*/
 959:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 960:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     LV_PROFILER_REFR_BEGIN;
 961:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*Draw the 'younger' sibling objects because they can be on top_obj*/
 962:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     lv_obj_t * parent;
 963:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     lv_obj_t * border_p = top_obj;
 964:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 965:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     parent = lv_obj_get_parent(top_obj);
 966:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 967:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*Calculate the recolor before the parent*/
 968:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     if(parent) {
 969:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         layer->recolor = lv_obj_get_style_recolor_recursive(parent, LV_PART_MAIN);
 970:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     }
 971:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 972:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*Refresh the top object and its children*/
 973:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     refr_obj(layer, top_obj);
 974:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
 975:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     /*Do until not reach the screen*/
 976:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****     while(parent != NULL) {
 977:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         bool go = false;
 978:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         uint32_t i;
 979:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         uint32_t child_cnt = lv_obj_get_child_count(parent);
 980:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         for(i = 0; i < child_cnt; i++) {
 981:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             lv_obj_t * child = parent->spec_attr->children[i];
 982:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             if(!go) {
 983:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****                 if(child == border_p) go = true;
 984:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             }
 985:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             else {
 986:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****                 /*Refresh the objects*/
 987:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****                 refr_obj(layer, child);
 988:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****             }
 989:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c ****         }
 990:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_refr.c **** 
