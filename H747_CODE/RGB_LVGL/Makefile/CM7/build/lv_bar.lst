 602:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     res = lv_obj_event_base(MY_CLASS, e);
 603:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     if(res != LV_RESULT_OK) return;
 604:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c **** 
 605:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     lv_event_code_t code = lv_event_get_code(e);
 606:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     lv_obj_t * obj = lv_event_get_current_target(e);
 607:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c **** 
 608:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     if(code == LV_EVENT_REFR_EXT_DRAW_SIZE) {
 609:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         int32_t indic_size;
 610:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         indic_size = lv_obj_calculate_ext_draw_size(obj, LV_PART_INDICATOR);
 611:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c **** 
 612:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         /*Bg size is handled by lv_obj*/
 613:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         int32_t * s = lv_event_get_param(e);
 614:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         *s = LV_MAX(*s, indic_size);
 615:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c **** 
 616:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         /*Calculate the indicator area*/
