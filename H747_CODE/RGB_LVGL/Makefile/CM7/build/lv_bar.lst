 618:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         int32_t bg_right = lv_obj_get_style_pad_right(obj, LV_PART_MAIN);
 619:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         int32_t bg_top = lv_obj_get_style_pad_top(obj, LV_PART_MAIN);
 620:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         int32_t bg_bottom = lv_obj_get_style_pad_bottom(obj, LV_PART_MAIN);
 621:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c **** 
 622:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         int32_t pad = LV_MIN4(bg_left, bg_right, bg_top, bg_bottom);
 623:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         if(pad < 0) {
 624:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****             *s = *s - pad;
 625:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         }
 626:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     }
 627:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     else if(code == LV_EVENT_PRESSED || code == LV_EVENT_RELEASED) {
 628:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         lv_bar_t * bar = (lv_bar_t *)obj;
 629:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****         lv_obj_invalidate_area(obj, &bar->indic_area);
 630:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     }
 631:../../Middlewares/LVGL/GUI/lvgl/src/widgets/bar/lv_bar.c ****     else if(code == LV_EVENT_DRAW_MAIN) {
