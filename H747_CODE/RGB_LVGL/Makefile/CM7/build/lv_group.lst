 162:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** void lv_group_remove_obj(lv_obj_t * obj)
 163:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** {
 164:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     lv_group_t * g = lv_obj_get_group(obj);
 165:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     if(g == NULL) return;
 166:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 167:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     LV_LOG_TRACE("begin");
 168:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 169:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     /*Focus on the next object*/
 170:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     if(g->obj_focus && *g->obj_focus == obj) {
 171:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         if(g->frozen) g->frozen = 0;
 172:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 173:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         /*If this is the only object in the group then focus to nothing.*/
 174:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         if(lv_ll_get_head(&g->obj_ll) == g->obj_focus && lv_ll_get_tail(&g->obj_ll) == g->obj_focus
 175:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****             lv_obj_send_event(*g->obj_focus, LV_EVENT_DEFOCUSED, get_indev(g));
 176:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         }
 177:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         /*If there more objects in the group then focus to the next/prev object*/
 178:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         else {
 179:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****             lv_group_refocus(g);
