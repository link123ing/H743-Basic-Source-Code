 182:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 183:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     /*If the focuses object is still the same then it was the only object in the group but it will
 184:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****      *be deleted. Set the `obj_focus` to NULL to get back to the initial state of the group with
 185:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****      *zero objects*/
 186:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     if(g->obj_focus && *g->obj_focus == obj) {
 187:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         g->obj_focus = NULL;
 188:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     }
 189:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 190:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     /*Search the object and remove it from its group*/
 191:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     lv_obj_t ** i;
