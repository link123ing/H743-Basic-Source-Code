 194:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****             lv_ll_remove(&g->obj_ll, i);
 195:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****             lv_free(i);
 196:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****             if(obj->spec_attr) obj->spec_attr->group_p = NULL;
