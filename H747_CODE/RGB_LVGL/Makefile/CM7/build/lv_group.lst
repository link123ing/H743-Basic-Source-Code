 117:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** {
 118:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     if(group == NULL) return;
 119:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 120:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     LV_LOG_TRACE("begin");
 121:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 122:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     /*Be sure the object is removed from its current group*/
 123:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     lv_group_remove_obj(obj);
 124:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 125:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     if(obj->spec_attr == NULL) lv_obj_allocate_spec_attr(obj);
 126:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     obj->spec_attr->group_p = group;
 127:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 128:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     lv_obj_t ** next = lv_ll_ins_tail(&group->obj_ll);
 129:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     LV_ASSERT_MALLOC(next);
 130:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     if(next == NULL) return;
 131:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     *next = obj;
 132:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 133:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     /*If the head and the tail is equal then there is only one object in the linked list.
 134:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****      *In this case automatically activate it*/
 135:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     if(lv_ll_get_head(&group->obj_ll) == next) {
 136:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         lv_group_refocus(group);
 137:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     }
 138:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 139:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     LV_LOG_TRACE("finished");
 140:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** }
