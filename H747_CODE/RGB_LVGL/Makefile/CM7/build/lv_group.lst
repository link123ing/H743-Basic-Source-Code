 151:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     LV_LL_READ(&g1->obj_ll, obj_i) {
 152:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         if((*obj_i) == obj1)(*obj_i) = obj2;
 153:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****         else if((*obj_i) == obj2)(*obj_i) = obj1;
 154:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     }
 155:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 156:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     lv_obj_t * focused = lv_group_get_focused(g1);
 157:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     if(focused == obj1) lv_group_focus_obj(obj2);
 158:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c ****     else if(focused == obj2) lv_group_focus_obj(obj1);
 159:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** 
 160:../../Middlewares/LVGL/GUI/lvgl/src/core/lv_group.c **** }
