 100:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 101:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         timer_active = lv_ll_get_head(timer_head);
 102:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         while(timer_active) {
 103:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             /*The timer might be deleted if it runs only once ('repeat_count = 1')
 104:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****              *So get next element until the current is surely valid*/
 105:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             next = lv_ll_get_next(timer_head, timer_active);
 106:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 107:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             if(lv_timer_exec(timer_active)) {
 108:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                 /*If a timer was created or deleted then this or the next item might be corrupted*/
 109:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                 if(state_p->timer_created || state_p->timer_deleted) {
 110:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                     LV_TRACE_TIMER("Start from the first timer again because a timer was created or
 111:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                     break;
