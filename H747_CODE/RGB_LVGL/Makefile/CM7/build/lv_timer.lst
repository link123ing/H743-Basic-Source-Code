  68:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     /*Avoid concurrent running of the timer handler*/
  69:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     if(state_p->already_running) {
  70:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         LV_TRACE_TIMER("already running, concurrent calls are not allow, returning");
