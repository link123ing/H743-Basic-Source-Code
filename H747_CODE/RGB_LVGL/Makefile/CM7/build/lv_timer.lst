 358:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** /**
 359:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****  * Find out how much time remains before a timer must be run.
 360:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****  * @param timer pointer to lv_timer
 361:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****  * @return the time remaining, or 0 if it needs to be run again
 362:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****  */
 363:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** static uint32_t lv_timer_time_remaining(lv_timer_t * timer)
 364:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** {
 365:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     /*Check if at least 'period' time elapsed*/
