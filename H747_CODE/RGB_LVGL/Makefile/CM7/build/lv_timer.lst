 306:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** /**
 307:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****  * Execute timer if its remaining time is zero
 308:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****  * @param timer pointer to lv_timer
 309:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****  * @return true: execute, false: not executed
 310:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****  */
 311:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** static bool lv_timer_exec(lv_timer_t * timer)
 312:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** {
 313:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     if(timer->paused) return false;
 314:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 315:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     bool exec = false;
 316:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     if(lv_timer_time_remaining(timer) == 0) {
 317:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         /* Decrement the repeat count before executing the timer_cb.
ARM GAS  C:\Users\28576\AppData\Local\Temp\cc8FOiYN.s 			page 7


 318:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****          * If any timer is deleted `if(timer->repeat_count == 0)` is not executed below
 319:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****          * but at least the repeat count is zero and the timer can be deleted in the next round*/
 320:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         int32_t original_repeat_count = timer->repeat_count;
 321:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         if(timer->repeat_count > 0) timer->repeat_count--;
 322:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         timer->last_run = lv_tick_get();
 323:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         LV_TRACE_TIMER("calling timer callback: %p", *((void **)&timer->timer_cb));
 324:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 325:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         if(timer->timer_cb && original_repeat_count != 0) {
 326:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             LV_PROFILER_TIMER_BEGIN_TAG("timer_cb");
 327:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             timer->timer_cb(timer);
 328:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             LV_PROFILER_TIMER_END_TAG("timer_cb");
 329:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         }
 330:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 331:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         if(!state.timer_deleted) {
 332:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             LV_TRACE_TIMER("timer callback %p finished", *((void **)&timer->timer_cb));
 333:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         }
 334:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         else {
 335:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             LV_TRACE_TIMER("timer callback finished");
 336:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         }
 337:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 338:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         LV_ASSERT_MEM_INTEGRITY();
 339:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         exec = true;
 340:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     }
 341:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 342:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     if(state.timer_deleted == false) { /*The timer might be deleted by itself as well*/
 343:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         if(timer->repeat_count == 0) { /*The repeat count is over, delete the timer*/
 344:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             if(timer->auto_delete) {
 345:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                 LV_TRACE_TIMER("deleting timer with %p callback because the repeat count is over", 
 346:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                 lv_timer_delete(timer);
 347:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             }
 348:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             else {
 349:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                 LV_TRACE_TIMER("pausing timer with %p callback because the repeat count is over", *
 350:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                 lv_timer_pause(timer);
 351:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             }
 352:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         }
 353:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     }
 354:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 355:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     return exec;
 356:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** }
