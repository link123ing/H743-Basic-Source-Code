 113:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             }
 114:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 115:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             timer_active = next; /*Load the next timer*/
 116:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         }
 117:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     } while(timer_active);
 118:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 119:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     uint32_t time_until_next = LV_NO_TIMER_READY;
 120:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     next = lv_ll_get_head(timer_head);
 121:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     while(next) {
 122:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         if(!next->paused) {
 123:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             uint32_t delay = lv_timer_time_remaining(next);
 124:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****             if(delay < time_until_next)
 125:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****                 time_until_next = delay;
 126:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         }
 127:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 128:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****         next = lv_ll_get_next(timer_head, next); /*Find the next timer*/
 129:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     }
 130:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c **** 
 131:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     state_p->busy_time += lv_tick_elaps(handler_start);
 132:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_timer.c ****     uint32_t idle_period_time = lv_tick_elaps(state_p->idle_period_start);
