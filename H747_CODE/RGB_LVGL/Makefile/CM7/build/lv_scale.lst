1481:../../Middlewares/LVGL/GUI/lvgl/src/widgets/scale/lv_scale.c ****                 if(LV_SCALE_TICK_IDX_DEFAULT_ID == section->last_tick_idx_in_section) {
1482:../../Middlewares/LVGL/GUI/lvgl/src/widgets/scale/lv_scale.c ****                     /* This gets it initialized when the beginning and ending range values are the 
1483:../../Middlewares/LVGL/GUI/lvgl/src/widgets/scale/lv_scale.c ****                     section->last_tick_idx_in_section = tick_idx;
1484:../../Middlewares/LVGL/GUI/lvgl/src/widgets/scale/lv_scale.c ****                     section->last_tick_idx_is_major = is_major_tick;
1485:../../Middlewares/LVGL/GUI/lvgl/src/widgets/scale/lv_scale.c ****                 }
1486:../../Middlewares/LVGL/GUI/lvgl/src/widgets/scale/lv_scale.c ****                 /* Now keep setting the `last_tick_idx_...` values as we
