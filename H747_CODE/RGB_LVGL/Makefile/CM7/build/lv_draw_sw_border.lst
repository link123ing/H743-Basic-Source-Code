  55:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c **** {
  56:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     if(dsc->opa <= LV_OPA_MIN) return;
  57:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     if(dsc->width == 0) return;
  58:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     if(dsc->side == LV_BORDER_SIDE_NONE) return;
  59:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c **** 
  60:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     int32_t coords_w = lv_area_get_width(coords);
  61:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     int32_t coords_h = lv_area_get_height(coords);
  62:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     int32_t rout = dsc->radius;
  63:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     int32_t short_side = LV_MIN(coords_w, coords_h);
  64:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     if(rout > short_side >> 1) rout = short_side >> 1;
