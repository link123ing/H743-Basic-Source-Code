  69:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     area_inner.x1 += ((dsc->side & LV_BORDER_SIDE_LEFT) ? dsc->width : - (dsc->width + rout));
  70:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     area_inner.x2 -= ((dsc->side & LV_BORDER_SIDE_RIGHT) ? dsc->width : - (dsc->width + rout));
