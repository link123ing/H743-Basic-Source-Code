  72:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     area_inner.y2 -= ((dsc->side & LV_BORDER_SIDE_BOTTOM) ? dsc->width : - (dsc->width + rout));
  73:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c **** 
  74:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     int32_t rin = rout - dsc->width;
  75:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     if(rin < 0) rin = 0;
  76:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c **** 
  77:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     if(rout == 0 && rin == 0) {
  78:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****         draw_border_simple(t, coords, &area_inner, dsc->color, dsc->opa);
  79:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_border.c ****     }
