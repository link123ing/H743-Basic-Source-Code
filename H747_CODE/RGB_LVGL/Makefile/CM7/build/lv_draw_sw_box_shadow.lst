  60:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     /*Calculate the rectangle which is blurred to get the shadow in `shadow_area`*/
  61:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     lv_area_t core_area;
  62:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     core_area.x1 = coords->x1  + dsc->ofs_x - dsc->spread;
  63:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     core_area.x2 = coords->x2  + dsc->ofs_x + dsc->spread;
  64:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     core_area.y1 = coords->y1  + dsc->ofs_y - dsc->spread;
  65:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     core_area.y2 = coords->y2  + dsc->ofs_y + dsc->spread;
  66:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c **** 
  67:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     /*Calculate the bounding box of the shadow*/
  68:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     lv_area_t shadow_area;
  69:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     shadow_area.x1 = core_area.x1 - dsc->width / 2 - 1;
  70:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     shadow_area.x2 = core_area.x2 + dsc->width / 2 + 1;
  71:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     shadow_area.y1 = core_area.y1 - dsc->width / 2 - 1;
  72:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     shadow_area.y2 = core_area.y2 + dsc->width / 2 + 1;
  73:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c **** 
  74:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     lv_opa_t opa = dsc->opa;
  75:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     if(opa > LV_OPA_MAX) opa = LV_OPA_COVER;
  76:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c **** 
  77:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     /*Get clipped draw area which is the real draw area.
  78:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****      *It is always the same or inside `shadow_area`*/
  79:../../Middlewares/LVGL/GUI/lvgl/src/draw/sw/lv_draw_sw_box_shadow.c ****     lv_area_t draw_area;
