  52:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c **** int32_t LV_ATTRIBUTE_FAST_MEM lv_trigo_sin(int16_t angle)
  53:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c **** {
  54:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     int32_t ret = 0;
  55:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     while(angle < 0) angle += 360;
  56:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     while(angle >= 360) angle -= 360;
  57:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c **** 
  58:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     if(angle < 90) {
  59:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****         ret = sin0_90_table[angle];
  60:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     }
  61:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     else if(angle >= 90 && angle < 180) {
  62:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****         angle = 180 - angle;
  63:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****         ret   = sin0_90_table[angle];
  64:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     }
  65:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     else if(angle >= 180 && angle < 270) {
  66:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****         angle = angle - 180;
  67:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****         ret   = -sin0_90_table[angle];
  68:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     }
  69:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     else {   /*angle >=270*/
  70:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****         angle = 360 - angle;
  71:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****         ret   = -sin0_90_table[angle];
  72:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     }
  73:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c **** 
  74:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     if(ret == 32767) return 32768;
  75:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     else if(ret == -32767) return -32768;
  76:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c ****     else return ret;
  77:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_math.c **** }
