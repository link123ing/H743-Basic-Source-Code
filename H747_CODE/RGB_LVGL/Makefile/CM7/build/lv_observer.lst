 297:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c **** void lv_subject_deinit(lv_subject_t * subject)
 298:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c **** {
 299:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     lv_observer_t * observer = lv_ll_get_head(&subject->subs_ll);
 300:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     while(observer) {
 301:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****         lv_observer_t * observer_next = lv_ll_get_next(&subject->subs_ll, observer);
 302:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c **** 
 303:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****         lv_observer_remove(observer);
 304:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****         observer = observer_next;
 305:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     }
 306:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c **** 
 307:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     lv_ll_clear(&subject->subs_ll);
 308:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c **** }
