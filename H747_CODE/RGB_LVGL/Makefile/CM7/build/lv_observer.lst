 287:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     group_subject->value.pointer = list;
 288:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c **** 
 289:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     /* Bind all list[] subjects to `group_subject`. */
 290:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     uint32_t i;
 291:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     for(i = 0; i < list_len; i++) {
 292:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****         /* If a subject in `list[]` changes, notify `group_subject`. */
 293:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****         lv_subject_add_observer(list[i], group_notify_cb, group_subject);
 294:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c ****     }
 295:../../Middlewares/LVGL/GUI/lvgl/src/others/observer/lv_observer.c **** }
