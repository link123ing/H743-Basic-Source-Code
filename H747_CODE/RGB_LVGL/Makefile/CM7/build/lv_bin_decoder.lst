 888:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****         uint8_t mask = (1 << bpp) - 1;
 889:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****         uint8_t shift = 0;
 890:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****         for(uint32_t i = 0; i < buf_len; i++) {
 891:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****             /**
