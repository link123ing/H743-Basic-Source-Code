 900:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****             uint8_t value = ((*in >> shift) & mask);
 901:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****             *out = bit_extend(value, bpp);
 902:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****             shift += bpp;
 903:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****             if(shift >= 8) {
 904:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****                 shift = 0;
 905:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****                 in--;
 906:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****             }
 907:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****             out--;
 908:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****         }
 909:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****     }
 910:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c **** 
 911:../../Middlewares/LVGL/GUI/lvgl/src/libs/bin_decoder/lv_bin_decoder.c ****     decoder_data->decoded = decoded;
