 128:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c **** 
 129:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****     const lv_result_t iter_res = iter->next_cb(iter->instance, iter->context, elem);
 130:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****     if(iter_res == LV_RESULT_INVALID) return LV_RESULT_INVALID;
 131:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c **** 
 132:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****     if(c_buf != NULL) iter->peek_offset = 0;
 133:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c **** 
 134:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****     return iter_res;
