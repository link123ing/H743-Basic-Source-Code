 122:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****     if(c_buf != NULL && !lv_circle_buf_is_empty(c_buf)) {
 123:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****         if(elem) lv_circle_buf_read(c_buf, elem);
 124:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****         else lv_circle_buf_skip(c_buf);
 125:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****         iter->peek_offset = 0;
 126:../../Middlewares/LVGL/GUI/lvgl/src/misc/lv_iter.c ****         return LV_RESULT_OK;
