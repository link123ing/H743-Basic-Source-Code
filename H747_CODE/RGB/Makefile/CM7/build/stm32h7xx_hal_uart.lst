3663:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****     /* Enable the UART Transmit Complete Interrupt */
3664:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****     ATOMIC_SET_BIT(huart->Instance->CR1, USART_CR1_TCIE);
3665:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   }
3666:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   /* DMA Circular mode */
3667:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   else
3668:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   {
3669:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c **** #if (USE_HAL_UART_REGISTER_CALLBACKS == 1)
3670:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****     /*Call registered Tx complete callback*/
