3654:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   /* DMA Normal mode */
3655:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   if (hdma->Init.Mode != DMA_CIRCULAR)
3656:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   {
