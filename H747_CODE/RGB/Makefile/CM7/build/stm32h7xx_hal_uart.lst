3705:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c **** 
3706:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   /* DMA Normal mode */
3707:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   if (hdma->Init.Mode != DMA_CIRCULAR)
3708:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   {
