3733:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   /* Check current reception Mode :
3734:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****      If Reception till IDLE event has been selected : use Rx Event callback */
3735:../../Drivers/STM32H7xx_HAL_Driver/Src/stm32h7xx_hal_uart.c ****   if (huart->ReceptionType == HAL_UART_RECEPTION_TOIDLE)
